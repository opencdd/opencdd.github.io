{
  "name": "opencdd-browser",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "OpenCDD Browser — Astro-based static browser for published IEC CDD data.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "npm run gen-tree && astro check && astro build && pagefind --site dist",
    "preview": "astro preview",
    "check": "astro check",
    "typecheck": "astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "fetch-data": "tsx scripts/fetch-data.ts",
    "gen-tree": "tsx scripts/gen-tree.ts"
  },
  "dependencies": {
    "@opencdd/models": "^0.1.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/vue": "^7.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^22.10.5",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.10",
    "astro": "^7.0.7",
    "jsdom": "^25.0.1",
    "pagefind": "^1.3.0",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.2.0"
  }
}
