{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "verbatimModuleSyntax": false,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "~": ["./src"],
      "~/*": ["./src/*"]
    },
    "types": ["node"]
  },
  "vueCompilerOptions": {},
  "include": ["src", "scripts", "tests", ".astro/types.d.ts"],
  "exclude": ["dist", "node_modules"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
