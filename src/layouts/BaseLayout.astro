---
import "~/styles/global.css";
import SkipToContent from "~/components/ui/SkipToContent.astro";
import Header from "~/components/layout/Header.astro";
import Footer from "~/components/layout/Footer.astro";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "OpenCDD — a modern browser for published IEC CDD data." } =
  Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <SkipToContent />
    <Header />
    <main id="main-content" class="mx-auto w-full max-w-7xl flex-1 px-6 py-6 lg:px-8">
      <slot />
    </main>
    <Footer />
  </body>
</html>
