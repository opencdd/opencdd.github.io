---
import "~/styles/global.css";
import { ClientRouter } from "astro:transitions";
import SkipToContent from "~/components/ui/SkipToContent.astro";
import Header from "~/components/layout/Header.astro";
import Footer from "~/components/layout/Footer.astro";
import CommandPalette from "~/components/islands/CommandPalette.vue";
import { listDictionaries } from "~/lib/dictionary";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "OpenCDD — a modern browser for published IEC CDD data." } =
  Astro.props;

const dicts = listDictionaries().map((d) => ({
  slug: d.slug,
  title: d.shortTitle,
  entityCount: Object.values(d.counts).reduce((s: number, n) => s + (n as number), 0),
}));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
    <link rel="icon" type="image/png" href="/favicon-96x96.png?v=20260712" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=20260712" />
    <link rel="shortcut icon" href="/favicon.ico?v=20260712" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=20260712" />
    <link rel="manifest" href="/site.webmanifest?v=20260712" />
    <meta name="theme-color" content="#fbfaf3" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#141c28" media="(prefers-color-scheme: dark)" />
  </head>
  <body>
    <SkipToContent />
    <Header />
    <main id="main-content" class="mx-auto w-full max-w-7xl flex-1 px-6 py-6 lg:px-8">
      <slot />
    </main>
    <Footer />
    <CommandPalette client:only="vue" dictionaries={dicts} />
  </body>
</html>
