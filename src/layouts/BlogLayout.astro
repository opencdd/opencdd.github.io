---
import ProseLayout from "~/layouts/ProseLayout.astro";

interface Props {
  title: string;
  description?: string;
  published: Date;
  updated?: Date;
  author?: string;
  tags?: string[];
}

const {
  title,
  description,
  published,
  updated,
  author = "OpenCDD",
  tags = [],
} = Astro.props;

const dateFmt = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<ProseLayout
  title={`${title} — OpenCDD Blog`}
  description={description}
  width="narrow"
>
  <header slot="header" class="space-y-3 border-b border-paper-300 pb-6">
    <p class="text-xs font-medium uppercase tracking-wide text-ink-500">
      <a href="/blog/" class="hover:text-hex-700">← Blog</a>
    </p>
    <h1 class="font-display text-3xl tracking-tight text-ink-900">{title}</h1>
    {description && (
      <p class="text-base text-ink-600">{description}</p>
    )}
    <dl class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-ink-500">
      <div>
        <dt class="inline font-medium uppercase tracking-wide">By</dt>
        <dd class="ml-1 inline text-ink-700">{author}</dd>
      </div>
      <div>
        <dt class="inline font-medium uppercase tracking-wide">Published</dt>
        <dd class="ml-1 inline text-ink-700">{dateFmt.format(published)}</dd>
      </div>
      {updated && (
        <div>
          <dt class="inline font-medium uppercase tracking-wide">Updated</dt>
          <dd class="ml-1 inline text-ink-700">{dateFmt.format(updated)}</dd>
        </div>
      )}
    </dl>
    {tags.length > 0 && (
      <ul class="flex flex-wrap gap-1.5 pt-1">
        {tags.map((tag) => (
          <li class="rounded-full bg-paper-200 px-2 py-0.5 text-[11px] font-medium text-ink-600">
            #{tag}
          </li>
        ))}
      </ul>
    )}
  </header>

  <footer slot="footer" class="mt-12 border-t border-paper-300 pt-6 text-sm text-ink-500">
    <p>
      OpenCDD is an open-source project on{" "}
      <a
        href="https://github.com/opencdd"
        class="text-hex-700 underline underline-offset-2"
        >GitHub</a
      >.
    </p>
  </footer>
</ProseLayout>
