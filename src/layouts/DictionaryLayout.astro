---
import "~/styles/global.css";
import SkipToContent from "~/components/ui/SkipToContent.astro";
import Header from "~/components/layout/Header.astro";
import Footer from "~/components/layout/Footer.astro";
import KeyboardShortcuts from "~/components/layout/KeyboardShortcuts.astro";
import ClassTree from "~/components/islands/ClassTree.vue";
import BackToTop from "~/components/islands/BackToTop.vue";
import { loadDictionary } from "~/lib/data";

interface Props {
  title: string;
  description?: string;
  dict: string;
}

const { title, description, dict } = Astro.props;
const bundle = loadDictionary(dict);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon-96x96.png?v=20260712" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=20260712" />
    <link rel="shortcut icon" href="/favicon.ico?v=20260712" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=20260712" />
    <link rel="manifest" href="/site.webmanifest?v=20260712" />
    <meta name="theme-color" content="#fbfaf3" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#141c28" media="(prefers-color-scheme: dark)" />
  </head>
  <body>
    <SkipToContent />
    <Header />
    <div class="mx-auto flex w-full max-w-7xl flex-1 flex-col gap-4 px-4 py-4 lg:flex-row lg:px-6 lg:py-6">
      <aside
        aria-label="Class tree"
        class="hidden shrink-0 lg:block lg:w-72 lg:overflow-y-auto lg:max-h-[calc(100vh-7rem)] lg:sticky lg:top-20 lg:pr-2 scroll-thin"
      >
        <ClassTree
          client:only="vue"
          dict={dict}
          initialHighlightedIrdi={Astro.url.pathname}
        />
      </aside>
      <section
        id="main-content"
        aria-label="Dictionary content"
        class="min-w-0 flex-1 animate-fade-in"
      >
        <slot />
      </section>
      <aside
        aria-label="On this page"
        class="hidden shrink-0 xl:block xl:w-56 xl:sticky xl:top-20 xl:self-start xl:max-h-[calc(100vh-7rem)] xl:overflow-y-auto scroll-thin"
      >
        <slot name="sidebar-right" />
      </aside>
    </div>
    <Footer />
    <KeyboardShortcuts />
    <BackToTop client:only="vue" />
  </body>
</html>
