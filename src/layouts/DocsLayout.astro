---
import BaseLayout from "~/layouts/BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  docsNav: { href: string; title: string; order: number }[];
}

const { title, description, docsNav } = Astro.props;
const sorted = [...docsNav].sort((a, b) => a.order - b.order);
const current = Astro.url.pathname;
---

<BaseLayout title={`${title} — OpenCDD Docs`} description={description}>
  <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[220px_minmax(0,1fr)]">
    <aside class="hidden lg:block">
      <p
        class="mb-2 text-[10px] font-semibold uppercase tracking-[0.08em] text-ink-400"
      >
        Documentation
      </p>
      <nav>
        <ul class="space-y-0.5 border-l border-ink-200">
          {sorted.map((item) => {
            const active = current === item.href || current === item.href + "/";
            return (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "block border-l-2 -ml-px py-0.5 pl-3 text-sm transition",
                    active
                      ? "border-accent-600 font-medium text-accent-700"
                      : "border-transparent text-ink-500 hover:border-ink-300 hover:text-ink-800",
                  ]}
                >
                  {item.title}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>
    </aside>

    <article class="prose-opencdd max-w-3xl">
      <slot />
    </article>
  </div>
</BaseLayout>
