  "preferred_name": "Over-current release",
  "preferred_name_ml": {
    "en": "Over-current release",
    "fr": "Protection contre la surintensité",
    "de": "Überstromauslöser",
    "zh": "过电流脱扣器"
  },
  "definition": "release which causes a mechanical switching device to open when the current in the release exceeds a predetermined value",
  "definition_ml": {
    "en": "release which causes a mechanical switching device to open when the current in the release exceeds a predetermined value",
    "fr": "déclencheur qui permet l'ouverture d'un appareil mécanique de connexion, lorsque le courant dans le déclencheur dépasse une valeur prédéterminée",
    "de": "Auslöser, der das Öffnen eines mechanischen Schaltgeräts verursacht, wenn der Strom in dem Auslöser einen vorgegebenen Wert überschreitet",
    "zh": "当电流超过预定值时，使机械开关电器断开的脱扣器。"
  },
