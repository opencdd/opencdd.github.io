  "preferred_name": "non-linearity (terminal-based)",
  "preferred_name_ml": {
    "en": "non-linearity (terminal-based)",
    "fr": "non-linéarité (système de bornes)",
    "de": "Nichtlinearität bei Grenzpunkteinstellung"
  },
  "definition": "non-linearity determined by drawing a straight line so that it coincides, with the average calibration curve at the upper range value and at the lower range value",
  "definition_ml": {
    "en": "non-linearity determined by drawing a straight line so that it coincides, with the average calibration curve at the upper range value and at the lower range value",
    "fr": "non-linéarité déterminée en traçant une droite coïncidant avec la courbe d'étalonnage moyenne à la valeur supérieure de l'échelle et à la valeur inférieure de l'échelle",
    "de": "Nichtlinearität, die ermittelt wird, indem eine Gerade so eingezeichnet wird, dass sie die mittlere Kalibrierkurve im Endwert und im Anfangswert schneidet"
  },
