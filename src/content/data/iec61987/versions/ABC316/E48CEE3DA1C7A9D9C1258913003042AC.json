{
  "irdi": "0112/2///61987#ABC316",
  "code": "ABC316",
  "version": "8",
  "revision": "1",
  "preferred_name": "Limiting environmental design conditions",
  "preferred_name_ml": {
    "en": "Limiting environmental design conditions",
    "fr": "Conditions de conception environnementales limitantes",
    "de": "Umgebungsauslegungsbedingungen (Grenzbedingungen)"
  },
  "definition": "properties characterizing the extreme range of environmental conditions that a device shall be designed to withstand without permanent damage",
  "definition_ml": {
    "en": "properties characterizing the extreme range of environmental conditions that a device shall be designed to withstand without permanent damage",
    "fr": "propriétés caractérisant l’étendue extrême de conditions environnementales qu’un appareil doit pouvoir supporter par conception sans dommages permanents de ses caractéristiques de mesure",
    "de": "Merkmale, die die extremen Umgebungsbedingungen charakterisieren, für die ein Gerät auszulegen ist, ohne dass ein bleibender Schaden entsteht"
  },
  "synonyms": [],
  "note": "The device must measure within specification, if necessary after calibration, when the condition returns to its normal range",
  "note_ml": {
    "en": "The device must measure within specification, if necessary after calibration, when the condition returns to its normal range",
    "de": "Das Gerät muss im Rahmen seiner Spezifizierung messen, gegebenenfalls nach einer Kalibrierung, wenn die Bedingungen wieder im Normalbereich sind"
  },
