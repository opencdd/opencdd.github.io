  "preferred_name": "start-up drift",
  "preferred_name_ml": {
    "en": "start-up drift",
    "fr": "dérive au démarrage",
    "de": "Einschaltdrift"
  },
  "definition": "time duration for the output to reach and remain within the manufacturer's specified limits with a 90% input signal applied to the device",
  "definition_ml": {
    "en": "time duration for the output to reach and remain within the manufacturer's specified limits with a 90% input signal applied to the device",
