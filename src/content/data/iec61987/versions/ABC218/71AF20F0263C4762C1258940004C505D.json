  "preferred_name": "Electrical power input circuit",
  "preferred_name_ml": {
    "en": "Electrical power input circuit",
    "fr": "Circuit d'entrée d'alimentation électrique",
    "de": "Elektrische Eingangs-Energieversorgung"
  },
  "definition": "properties characterizing a permanent or temporary electrical power to be supplied to the device in order to maintain its function, which cannot be taken from the input signal",
  "definition_ml": {
    "en": "properties characterizing a permanent or temporary electrical power to be supplied to the device in order to maintain its function, which cannot be taken from the input signal",
    "fr": "propriétés caractérisant une alimentation électrique permanente ou temporaire à fournir à l’équipement de mesure afin de maintenir sa fonction, qui ne peut pas être extraite du signal d’entrée",
    "de": "Merkmale, die eine dauerhafte oder temporäre Energieversorgung für ein Gerät kennzeichnen, die zu deren Betrieb notwendig ist und nicht aus dem Eingangssignal bezogen werden kann"
  },
