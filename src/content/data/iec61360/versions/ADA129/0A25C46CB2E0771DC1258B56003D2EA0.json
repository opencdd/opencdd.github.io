  "preferred_name": "short-circuit power loss",
  "preferred_name_ml": {
    "en": "short-circuit power loss",
    "de": "Kurzschlussleistungsverlust"
  },
  "definition": "thermal power loss caused by the over- current in a short-circuit or in a situation equivalent to a short-circuit measured at  given duration and at rated ambient temperature",
