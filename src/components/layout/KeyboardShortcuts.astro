<script>
  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      const currentPath = window.location.pathname;
      if (currentPath !== "/search") {
        window.location.href = "/search";
      }
    }
  });
</script>
