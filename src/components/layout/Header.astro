---
import { platformModifierLabel } from "~/lib/platform";
import { primaryNav, navItemIsActive } from "~/lib/siteNav";
import LanguageSwitcher from "~/components/islands/LanguageSwitcher.vue";
import MobileNav from "~/components/islands/MobileNav.vue";
const modifier = platformModifierLabel();
const current = Astro.url.pathname;
---

<header class="sticky top-0 z-30 border-b border-paper-300/80 bg-paper-50/85 backdrop-blur-md print:hidden">
  <div class="mx-auto flex max-w-7xl items-center gap-6 px-6 py-3 lg:px-8">
    <a
      href="/"
      class="group flex shrink-0 items-center gap-3 rounded-md px-1 py-0.5 transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-hex-600"
      aria-label="OpenCDD home"
    >
      <img
        src="/img/logo-64.png"
        alt=""
        aria-hidden="true"
        width="32"
        height="32"
        class="h-8 w-8 rounded-md shadow-sm transition group-hover:shadow-md"
        decoding="async"
      />
      <span class="flex items-baseline gap-2">
        <span class="font-display text-lg font-medium tracking-tight text-ink-900">OpenCDD</span>
        <span class="hidden text-[11px] font-normal uppercase tracking-[0.12em] text-ink-400 sm:inline">
          Common Data Dictionary
        </span>
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-1 text-sm" aria-label="Primary">
      {primaryNav.map((item) => {
        const active = navItemIsActive(item, current);
        return (
          <a
            href={item.href}
            class:list={[
              "rounded-md px-2.5 py-1.5 transition",
              active
                ? "text-ink-900 bg-paper-200/70 font-medium"
                : "text-ink-600 hover:bg-paper-200/50 hover:text-ink-900",
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="flex flex-1 items-center justify-end gap-3">
      <LanguageSwitcher client:load transition:persist />
      <a
        href="/search"
        class="hidden md:inline-flex items-center gap-2 rounded-lg border border-paper-300 bg-paper-50 px-3 py-1.5 text-sm text-ink-500 transition hover:border-paper-400 hover:text-ink-700"
        aria-label="Search (opens search page)"
      >
        <svg viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 3.39 9.83l3.39 3.39a.75.75 0 1 0 1.06-1.06l-3.39-3.39A5.5 5.5 0 0 0 9 3.5ZM5 9a4 4 0 1 1 8 0 4 4 0 0 1-8 0Z" />
        </svg>
        <span>Search</span>
      </a>
      <span class="hidden shrink-0 items-center gap-1 lg:flex">
        <kbd class="rounded border border-paper-300 bg-paper-100 px-1.5 py-0.5 font-mono text-[10px] text-ink-600" aria-hidden="true">
          {modifier}K
        </kbd>
      </span>
      <MobileNav client:load transition:persist />
    </div>
  </div>
</header>


