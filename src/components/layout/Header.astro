---
import { platformModifierLabel } from "~/lib/platform";
const modifier = platformModifierLabel();
---

<header class="sticky top-0 z-30 border-b border-ink-200/70 bg-white/85 backdrop-blur-md print:hidden">
  <div class="mx-auto flex max-w-7xl items-center gap-4 px-6 py-3 lg:px-8">
    <a
      href="/"
      class="group flex shrink-0 items-center gap-2.5 rounded-md px-1 py-0.5 transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent-600"
    >
      <span
        aria-hidden="true"
        class="grid h-7 w-7 place-items-center rounded-lg bg-gradient-to-br from-accent-500 to-accent-700 text-white shadow-sm"
      >
        <svg viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4">
          <path d="M2 3.5A1.5 1.5 0 0 1 3.5 2h9A1.5 1.5 0 0 1 14 3.5v9a1.5 1.5 0 0 1-1.5 1.5h-9A1.5 1.5 0 0 1 2 12.5v-9Zm4.5 1.75a.75.75 0 0 0 0 1.5h3a.75.75 0 0 0 0-1.5h-3Zm-.75 3.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 0 0-1.5h-3a2.25 2.25 0 0 0 0 4.5h3a.75.75 0 0 0 0-1.5h-3a.75.75 0 0 1-.75-.75Z" />
        </svg>
      </span>
      <span class="flex items-baseline gap-1.5">
        <span class="text-base font-semibold tracking-tight text-ink-900">OpenCDD</span>
        <span class="rounded-full bg-accent-50 px-2 py-0.5 text-[11px] font-medium uppercase tracking-wider text-accent-700">Browser</span>
      </span>
    </a>
    <div class="flex flex-1 items-center justify-end gap-3">
      <a
        href="/search"
        class="inline-flex items-center gap-2 rounded-lg border border-ink-200 bg-sand-50 px-3 py-1.5 text-sm text-ink-500 transition hover:border-ink-300 hover:text-ink-700"
        aria-label="Search (opens search page)"
      >
        <svg viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 3.39 9.83l3.39 3.39a.75.75 0 1 0 1.06-1.06l-3.39-3.39A5.5 5.5 0 0 0 9 3.5ZM5 9a4 4 0 1 1 8 0 4 4 0 0 1-8 0Z" />
        </svg>
        <span>Search</span>
      </a>
      <span class="hidden shrink-0 items-center gap-1 lg:flex">
        <kbd class="rounded border border-ink-200 bg-sand-50 px-1.5 py-0.5 font-mono text-[10px] text-ink-600" aria-hidden="true">
          {modifier}K
        </kbd>
      </span>
    </div>
  </div>
</header>
