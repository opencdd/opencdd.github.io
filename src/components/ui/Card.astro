---
import { cn } from "~/lib/cn";

interface Props {
  class?: string;
  pad?: boolean;
}

const { class: className, pad = true } = Astro.props;
---

<div
  class={cn(
    "rounded-xl border border-ink-200/70 bg-paper-50 shadow-xs transition duration-200 hover:border-paper-300 hover:shadow-sm print:break-inside-avoid print:shadow-none",
    pad && "p-5",
    className,
  )}
>
  <slot />
</div>
