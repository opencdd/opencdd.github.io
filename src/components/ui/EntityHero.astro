---
import Badge from "./Badge.astro";
import IrdiPill from "./IrdiPill.astro";
import MultilingualText from "./MultilingualText.astro";
import CopyButton from "~/components/islands/CopyButton.vue";
import type { MultilingualText as MLText, EntityDates } from "~/lib/types";

interface StatItem {
  label: string;
  value: number;
  href?: string;
}

interface Props {
  title: string;
  irdi: string;
  definition?: string;
  titleTranslations?: MLText;
  definitionTranslations?: MLText;
  shortName?: string;
  version?: string;
  revision?: string;
  dates?: EntityDates;
  sourceDocument?: string;
  extraBadges?: unknown;
  stats?: StatItem[];
}

const {
  title,
  irdi,
  definition,
  titleTranslations,
  definitionTranslations,
  shortName,
  version,
  revision,
  dates,
  sourceDocument,
  stats = [],
} = Astro.props;

const pills: Array<{ key: string; tone: "neutral" | "accent"; text: string }> = [];
if (version) pills.push({ key: "version", tone: "neutral", text: `v${version}` });
if (revision) pills.push({ key: "revision", tone: "neutral", text: `rev ${revision}` });
if (dates?.current_version)
  pills.push({ key: "cv", tone: "neutral", text: dates.current_version });
if (sourceDocument) {
  pills.push({
    key: "src",
    tone: "accent",
    text: sourceDocument,
  });
}
---

<header class="relative overflow-hidden rounded-2xl border border-lapis-200/60 bg-gradient-to-br from-paper-50 via-paper-50 to-teal-500/5 px-6 py-5 shadow-xs print:bg-none print:break-inside-avoid print:shadow-none">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -right-16 -top-16 h-48 w-48 rounded-full bg-hex-300/10 blur-3xl"
  >
  </div>
  <div class="relative flex flex-wrap items-center gap-2">
    <slot name="badge" />
    {shortName && (
      <Badge tone="neutral">
        <span class="font-mono">{shortName}</span>
      </Badge>
    )}
    <slot name="extra-badges" />
    {pills.map((p) => (
      <Badge tone={p.tone}>
        {p.key === "src" && /^https?:\/\//.test(p.text) ? (
          <a
            href={p.text}
            target="_blank"
            rel="noreferrer noopener"
            class="underline decoration-dotted underline-offset-2"
          >
            {p.text}
          </a>
        ) : (
          p.text
        )}
      </Badge>
    ))}
  </div>
  <h1 class="relative mt-2 text-3xl font-semibold tracking-tight text-ink-900">
    <MultilingualText source={title} translations={titleTranslations} />
  </h1>
  <div class="relative mt-2.5 flex flex-wrap items-center gap-2">
    <IrdiPill irdi={irdi} />
    <CopyButton
      client:only="vue"
      value={Astro.url.href}
      label="Copy link"
    />
    <slot name="actions" />
  </div>
  {(definition || definitionTranslations) && (
    <p class="relative mt-3 max-w-3xl text-sm leading-relaxed text-ink-600">
      <MultilingualText source={definition} translations={definitionTranslations} />
    </p>
  )}
  {stats.length > 0 && (
    <dl class="relative mt-4 flex flex-wrap gap-x-6 gap-y-2 border-t border-paper-200/70 pt-3">
      {stats.map((s) => (
        <div class="flex items-baseline gap-1.5">
          <dt class="text-[11px] font-medium uppercase tracking-wide text-ink-500">
            {s.href ? (
              <a
                href={s.href}
                class="transition hover:text-lapis-700"
              >
                {s.label}
              </a>
            ) : (
              s.label
            )}
          </dt>
          <dd class="font-mono text-sm font-medium tabular-nums text-ink-800">
            {s.value.toLocaleString()}
          </dd>
        </div>
      ))}
    </dl>
  )}
  <slot />
</header>
