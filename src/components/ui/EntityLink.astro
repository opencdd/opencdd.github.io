---
import { resolveEntityRef } from "~/lib/entityRef";
import type { DictionaryBundle } from "~/lib/bundle";
import type { EntityType } from "~/lib/types";
import { codeFromIrdi } from "~/lib/irdi";

interface Props {
  slug: string;
  irdi: string;
  bundle: DictionaryBundle;
  code?: string;
  label?: string;
  type?: EntityType;
  showIrdi?: boolean;
  hideCode?: boolean;
}

const {
  slug,
  irdi,
  bundle,
  code,
  label,
  type,
  showIrdi = false,
  hideCode = false,
} = Astro.props;

const ref = resolveEntityRef(irdi, bundle, slug);
const identifier = showIrdi ? irdi : (code ?? ref.code);
const displayLabel = label ?? ref.name;
const hasHref = ref.href !== null;
const tooltip = ref.definition
  ? `${ref.code} — ${displayLabel}: ${ref.definition}`
  : `${ref.code} — ${displayLabel}`;
const brokenTitle = `⚠ Not in browser data — ${irdi}. The entity is referenced but its full record wasn't scraped.`;
---

{hasHref ? (
  <a
    href={ref.href}
    title={tooltip}
    data-entity-tooltip={ref.definition ?? ""}
    class="text-lapis-700 underline decoration-dotted underline-offset-2 transition hover:text-lapis-900 hover:decoration-solid"
  >
    {!hideCode && (
      <span class="mr-1 font-mono text-[10px] text-ink-400">{identifier}</span>
    )}
    {displayLabel}
  </a>
) : (
  <span
    class="inline-flex items-center gap-1 text-rose-600"
    title={brokenTitle}
  >
    {!hideCode && (
      <span class="font-mono text-[10px] text-rose-400 line-through decoration-rose-300">{identifier}</span>
    )}{" "}
    <span class="underline decoration-dotted decoration-rose-400 underline-offset-2">{displayLabel}</span>
    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" class="h-3 w-3 shrink-0 text-rose-500" aria-hidden="true">
      <path d="M6 3L3 3a1 1 0 0 0-1 1v3M10 3h3a1 1 0 0 1 1 1v3M6 13H3a1 1 0 0 1-1-1V9M10 13h3a1 1 0 0 0 1-1V9" stroke-linecap="round"/>
      <line x1="2" y1="2" x2="14" y2="14" stroke-linecap="round"/>
    </svg>
  </span>
)}
