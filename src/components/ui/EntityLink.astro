---
import { resolveEntityRef } from "~/lib/entityRef";
import type { DictionaryBundle } from "~/lib/bundle";
import type { EntityType } from "~/lib/types";
import { codeFromIrdi } from "~/lib/irdi";

interface Props {
  slug: string;
  irdi: string;
  bundle: DictionaryBundle;
  code?: string;
  label?: string;
  type?: EntityType;
  showIrdi?: boolean;
  hideCode?: boolean;
}

const {
  slug,
  irdi,
  bundle,
  code,
  label,
  type,
  showIrdi = false,
  hideCode = false,
} = Astro.props;

const ref = resolveEntityRef(irdi, bundle, slug);
const identifier = showIrdi ? irdi : (code ?? ref.code);
const displayLabel = label ?? ref.name;
const hasHref = ref.href !== null;
const tooltip = ref.definition
  ? `${ref.code} — ${displayLabel}: ${ref.definition}`
  : `${ref.code} — ${displayLabel}`;
---

{hasHref ? (
  <a
    href={ref.href}
    title={tooltip}
    data-entity-tooltip={ref.definition ?? ""}
    class="text-lapis-700 underline decoration-dotted underline-offset-2 transition hover:text-lapis-900 hover:decoration-solid"
  >
    {!hideCode && (
      <span class="mr-1 font-mono text-[10px] text-ink-400">{identifier}</span>
    )}
    {displayLabel}
  </a>
) : (
  <span class="text-ink-700" title={irdi}>
    {!hideCode && (
      <span class="mr-1 font-mono text-[10px] text-ink-400">{identifier}</span>
    )}
    {displayLabel}
  </span>
)}
