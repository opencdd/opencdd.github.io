---
import { entityRoute, detailableTypeOf } from "~/lib/entityTypeMeta";
import { codeFromIrdi } from "~/lib/irdi";
import type { DictionaryBundle } from "~/lib/bundle";
import type { EntityNode, EntityType } from "~/lib/types";

interface Props {
  slug: string;
  irdi: string;
  bundle: DictionaryBundle;
  /** Optional override code (skip the bundle lookup). */
  code?: string;
  /** Optional override label. */
  label?: string;
  /** Optional override type. */
  type?: EntityType;
  /** Show the full IRDI instead of the short code. */
  showIrdi?: boolean;
  /** Suppress the code prefix entirely. */
  hideCode?: boolean;
}

const {
  slug,
  irdi,
  bundle,
  code,
  label,
  type,
  showIrdi = false,
  hideCode = false,
} = Astro.props;

const node: EntityNode | undefined = bundle.find(irdi);
const resolvedType = type ?? node?.type ?? null;
const resolvedCode = code ?? node?.code ?? codeFromIrdi(irdi);
const resolvedLabel =
  label ?? node?.preferred_name ?? node?.code ?? codeFromIrdi(irdi);

const detailable = resolvedType ? detailableTypeOf({ type: resolvedType, irdi } as EntityNode) : null;
const identifier = showIrdi ? irdi : resolvedCode;
---

{detailable && resolvedType ? (
  <a
    href={entityRoute(slug, resolvedType, resolvedCode)}
    title={`${irdi} — ${resolvedLabel}`}
    class="text-lapis-700 underline decoration-dotted underline-offset-2 transition hover:text-lapis-900 hover:decoration-solid"
  >
    {!hideCode && (
      <span class="mr-1 font-mono text-[10px] text-ink-400">{identifier}</span>
    )}
    {resolvedLabel}
  </a>
) : (
  <span class="text-ink-700" title={irdi}>
    {!hideCode && (
      <span class="mr-1 font-mono text-[10px] text-ink-400">{identifier}</span>
    )}
    {resolvedLabel}
  </span>
)}
