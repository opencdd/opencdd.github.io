---
import { entityRoute, detailableTypeOf } from "~/lib/entityTypeMeta";
import { codeFromIrdi } from "~/lib/irdi";
import type { DictionaryBundle } from "~/lib/bundle";
import type { EntityNode, EntityType } from "~/lib/types";

interface Props {
  slug: string;
  irdi: string;
  bundle: DictionaryBundle;
  /** Optional override code (skip the bundle lookup). */
  code?: string;
  /** Optional override label. */
  label?: string;
  /** Optional override type. */
  type?: EntityType;
  /** Render the code in monospace alongside the label. */
  showCode?: boolean;
}

const {
  slug,
  irdi,
  bundle,
  code,
  label,
  type,
  showCode = false,
} = Astro.props;

const node: EntityNode | undefined = bundle.entities.get(irdi);
const resolvedType = type ?? node?.type ?? null;
const resolvedCode = code ?? node?.code ?? codeFromIrdi(irdi);
const resolvedLabel =
  label ?? node?.preferred_name ?? node?.code ?? codeFromIrdi(irdi);

const detailable = resolvedType ? detailableTypeOf({ type: resolvedType, irdi } as EntityNode) : null;
---

{detailable && resolvedType ? (
  <a
    href={entityRoute(slug, resolvedType, resolvedCode)}
    class="text-accent-700 underline decoration-dotted underline-offset-2 transition hover:text-accent-900 hover:decoration-solid"
  >
    {resolvedLabel}
    {showCode && (
      <span class="ml-1 font-mono text-[11px] text-ink-400">[{resolvedCode}]</span>
    )}
  </a>
) : (
  <span class="text-ink-700">
    {resolvedLabel}
    {showCode && (
      <span class="ml-1 font-mono text-[11px] text-ink-400">[{resolvedCode}]</span>
    )}
  </span>
)}
