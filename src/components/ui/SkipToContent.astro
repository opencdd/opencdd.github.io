---
interface Props {
  targetId?: string;
}

const { targetId = "main-content" } = Astro.props;
---

<a
  href={`#${targetId}`}
  class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-accent-600 focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-white focus:shadow-lg focus:outline-none"
>
  Skip to content
</a>
