---
import EntityLink from "./EntityLink.astro";
import DataTypeChip from "./DataTypeChip.astro";
import type { DictionaryBundle } from "~/lib/bundle";
import type { PropertyNode } from "~/lib/types";
import { codeFromIrdi } from "~/lib/irdi";

interface Props {
  slug: string;
  bundle: DictionaryBundle;
  properties: readonly PropertyNode[];
  empty?: string;
  /** When true, wraps in a collapsed <details> element. */
  collapsable?: boolean;
  /** Label for the collapsable summary. */
  label?: string;
}

const {
  slug,
  bundle,
  properties,
  empty = "No properties.",
  collapsable = false,
  label = "Properties",
} = Astro.props;
---

{properties.length === 0 ? (
  <p class="text-sm text-ink-500">{empty}</p>
) : collapsable ? (
  <details>
    <summary class="cursor-pointer select-none text-xs font-semibold uppercase tracking-[0.08em] text-ink-500 hover:text-ink-700">
      {label} ({properties.length}) — click to expand
    </summary>
    <div class="mt-2 overflow-x-auto scroll-thin -mx-2">
      <table class="min-w-full text-sm border-collapse">
        <thead>
          <tr class="border-b border-ink-200 text-left text-xs uppercase tracking-wide text-ink-500">
            <th scope="col" class="px-3 py-1.5 font-medium">Code</th>
            <th scope="col" class="px-3 py-1.5 font-medium">Name</th>
            <th scope="col" class="px-3 py-1.5 font-medium">Type</th>
            <th scope="col" class="px-3 py-1.5 font-medium">Unit</th>
            <th scope="col" class="px-3 py-1.5 font-medium">Definition</th>
          </tr>
        </thead>
        <tbody>
          {properties.map((p) => (
            <tr class="border-b border-ink-100 align-baseline transition hover:bg-sand-50/60">
              <td class="px-3 py-1.5 font-mono text-[11px] text-ink-600 whitespace-nowrap">
                {p.code ?? codeFromIrdi(p.irdi)}
              </td>
              <td class="px-3 py-1.5 font-medium text-ink-800">
                <EntityLink slug={slug} irdi={p.irdi} bundle={bundle} hideCode />
              </td>
              <td class="px-3 py-1.5">
                {p.data_type && (
                  <DataTypeChip raw={p.data_type} slug={slug} bundle={bundle} />
                )}
              </td>
              <td class="px-3 py-1.5 text-xs text-ink-600">
                {p.unit ? (
                  <EntityLink slug={slug} irdi={p.unit} bundle={bundle} hideCode />
                ) : (
                  <span class="text-ink-300">—</span>
                )}
              </td>
              <td class="px-3 py-1.5 text-xs text-ink-600 max-w-md">
                {p.definition ? (
                  <span class="line-clamp-2">{p.definition}</span>
                ) : (
                  <span class="text-ink-300">—</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </details>
) : (
  <div class="overflow-x-auto scroll-thin -mx-2">
    <table class="min-w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-ink-200 text-left text-xs uppercase tracking-wide text-ink-500">
          <th scope="col" class="px-3 py-1.5 font-medium">Code</th>
          <th scope="col" class="px-3 py-1.5 font-medium">Name</th>
          <th scope="col" class="px-3 py-1.5 font-medium">Type</th>
          <th scope="col" class="px-3 py-1.5 font-medium">Unit</th>
          <th scope="col" class="px-3 py-1.5 font-medium">Definition</th>
        </tr>
      </thead>
      <tbody>
        {properties.map((p) => (
          <tr class="border-b border-ink-100 align-baseline transition hover:bg-sand-50/60">
            <td class="px-3 py-1.5 font-mono text-[11px] text-ink-600 whitespace-nowrap">
              {p.code ?? codeFromIrdi(p.irdi)}
            </td>
            <td class="px-3 py-1.5 font-medium text-ink-800">
              <EntityLink slug={slug} irdi={p.irdi} bundle={bundle} hideCode />
            </td>
            <td class="px-3 py-1.5">
              {p.data_type && (
                <DataTypeChip raw={p.data_type} slug={slug} bundle={bundle} />
              )}
            </td>
            <td class="px-3 py-1.5 text-xs text-ink-600">
              {p.unit ? (
                <EntityLink slug={slug} irdi={p.unit} bundle={bundle} hideCode />
              ) : (
                <span class="text-ink-300">—</span>
              )}
            </td>
            <td class="px-3 py-1.5 text-xs text-ink-600 max-w-md">
              {p.definition ? (
                <span class="line-clamp-2">{p.definition}</span>
              ) : (
                <span class="text-ink-300">—</span>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
)}
