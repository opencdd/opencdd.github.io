---
import EntityLink from "./EntityLink.astro";
import DataTypeChip from "./DataTypeChip.astro";
import type { DictionaryBundle } from "~/lib/bundle";
import type { PropertyNode } from "~/lib/types";
import { codeFromIrdi } from "~/lib/irdi";

interface Props {
  slug: string;
  bundle: DictionaryBundle;
  properties: readonly PropertyNode[];
  empty?: string;
  collapsable?: boolean;
  label?: string;
}

const {
  slug,
  bundle,
  properties,
  empty = "No properties.",
  collapsable = false,
  label = "Properties",
} = Astro.props;
---

{properties.length === 0 ? (
  <p class="text-sm text-ink-500">{empty}</p>
) : collapsable ? (
  <details>
    <summary class="cursor-pointer select-none text-xs font-semibold uppercase tracking-[0.08em] text-ink-500 transition hover:text-lapis-700">
      {label} ({properties.length}) — click to expand
    </summary>
    <div class="mt-3 divide-y divide-paper-200">
      {properties.map((p) => {
        const code = p.code ?? codeFromIrdi(p.irdi);
        return (
          <article class="group py-3 first:pt-0 last:pb-0">
            <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
              <code class="shrink-0 rounded bg-paper-100 px-1.5 py-0.5 font-mono text-[10px] tracking-wide text-ink-500 transition group-hover:bg-lapis-50 group-hover:text-lapis-700">
                {code}
              </code>
              <span class="font-medium text-ink-900">
                <EntityLink slug={slug} irdi={p.irdi} bundle={bundle} hideCode />
              </span>
              {(p.data_type || p.unit) && (
                <span class="ml-auto flex flex-wrap items-center gap-1.5 text-[11px] text-ink-500">
                  {p.data_type && (
                    <DataTypeChip raw={p.data_type} slug={slug} bundle={bundle} />
                  )}
                  {p.unit && (
                    <span class="inline-flex items-center gap-1 rounded border border-teal-200 bg-teal-50 px-1.5 py-0.5 text-[10px] text-teal-700">
                      <EntityLink slug={slug} irdi={p.unit} bundle={bundle} hideCode />
                    </span>
                  )}
                </span>
              )}
            </div>
            {p.definition && (
              <p class="mt-1.5 max-w-3xl text-sm leading-relaxed text-ink-600">
                {p.definition}
              </p>
            )}
          </article>
        );
      })}
    </div>
  </details>
) : (
  <div class="divide-y divide-paper-200">
    {properties.map((p) => {
      const code = p.code ?? codeFromIrdi(p.irdi);
      return (
        <article class="group py-3 first:pt-0 last:pb-0">
          <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
            <code class="shrink-0 rounded bg-paper-100 px-1.5 py-0.5 font-mono text-[10px] tracking-wide text-ink-500 transition group-hover:bg-lapis-50 group-hover:text-lapis-700">
              {code}
            </code>
            <span class="font-medium text-ink-900">
              <EntityLink slug={slug} irdi={p.irdi} bundle={bundle} hideCode />
            </span>
            {(p.data_type || p.unit) && (
              <span class="ml-auto flex flex-wrap items-center gap-1.5 text-[11px] text-ink-500">
                {p.data_type && (
                  <DataTypeChip raw={p.data_type} slug={slug} bundle={bundle} />
                )}
                {p.unit && (
                  <span class="inline-flex items-center gap-1 rounded border border-teal-200 bg-teal-50 px-1.5 py-0.5 text-[10px] text-teal-700">
                    <EntityLink slug={slug} irdi={p.unit} bundle={bundle} hideCode />
                  </span>
                )}
              </span>
            )}
          </div>
          {p.definition && (
            <p class="mt-1.5 max-w-3xl text-sm leading-relaxed text-ink-600">
              {p.definition}
            </p>
          )}
        </article>
      );
    })}
  </div>
)}
