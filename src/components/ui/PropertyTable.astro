---
import EntityLink from "./EntityLink.astro";
import DataTypeChip from "./DataTypeChip.astro";
import type { DictionaryBundle } from "~/lib/bundle";
import type { PropertyNode } from "~/lib/types";
import { codeFromIrdi } from "~/lib/irdi";

interface Props {
  slug: string;
  bundle: DictionaryBundle;
  properties: readonly PropertyNode[];
  empty?: string;
}

const { slug, bundle, properties, empty = "No properties." } = Astro.props;
---

{properties.length === 0 ? (
  <p class="text-sm text-ink-500">{empty}</p>
) : (
  <div class="overflow-x-auto scroll-thin -mx-2">
    <table class="min-w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-ink-200 text-left text-xs uppercase tracking-wide text-ink-500">
          <th scope="col" class="sticky top-0 z-10 bg-white px-3 py-2 font-medium">Code</th>
          <th scope="col" class="sticky top-0 z-10 bg-white px-3 py-2 font-medium">Name</th>
          <th scope="col" class="sticky top-0 z-10 bg-white px-3 py-2 font-medium">Type</th>
          <th scope="col" class="sticky top-0 z-10 bg-white px-3 py-2 font-medium">Unit</th>
          <th scope="col" class="sticky top-0 z-10 bg-white px-3 py-2 font-medium">Definition</th>
        </tr>
      </thead>
      <tbody>
        {properties.map((p) => (
          <tr class="border-b border-ink-100 align-top transition hover:bg-sand-50/60">
            <td class="px-3 py-2 font-mono text-[11px] text-ink-600 whitespace-nowrap">
              {p.code ?? codeFromIrdi(p.irdi)}
            </td>
            <td class="px-3 py-2 font-medium text-ink-800">
              <EntityLink slug={slug} irdi={p.irdi} bundle={bundle} />
            </td>
            <td class="px-3 py-2">
              {p.data_type && (
                <DataTypeChip raw={p.data_type} slug={slug} bundle={bundle} />
              )}
            </td>
            <td class="px-3 py-2 text-xs text-ink-600">
              {p.unit ? (
                <EntityLink slug={slug} irdi={p.unit} bundle={bundle} />
              ) : (
                <span class="text-ink-300">—</span>
              )}
            </td>
            <td class="px-3 py-2 text-xs text-ink-600">
              {p.definition ?? <span class="text-ink-300">—</span>}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
)}
