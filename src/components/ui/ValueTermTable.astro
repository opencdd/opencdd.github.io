---
import EntityLink from "./EntityLink.astro";
import type { DictionaryBundle } from "~/lib/bundle";
import type { ValueTermNode } from "~/lib/types";

interface Props {
  slug: string;
  bundle: DictionaryBundle;
  terms: readonly ValueTermNode[];
}

const { slug, bundle, terms } = Astro.props;
---

{terms.length === 0 ? (
  <p class="text-sm text-ink-500">No terms.</p>
) : (
  <div class="divide-y divide-paper-200">
    {terms.map((t) => (
      <article class="group py-3 first:pt-0 last:pb-0">
        <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
          <code class="shrink-0 rounded bg-paper-100 px-1.5 py-0.5 font-mono text-[10px] tracking-wide text-ink-500 transition group-hover:bg-lapis-50 group-hover:text-lapis-700">
            {t.enumeration_code ?? t.code}
          </code>
          <span class="font-medium text-ink-900">
            <EntityLink slug={slug} irdi={t.irdi} bundle={bundle} hideCode />
          </span>
        </div>
        {t.definition && (
          <p class="mt-1.5 max-w-3xl text-sm leading-relaxed text-ink-600">
            {t.definition}
          </p>
        )}
      </article>
    ))}
  </div>
)}
