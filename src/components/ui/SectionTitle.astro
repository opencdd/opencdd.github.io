---
import { cn } from "~/lib/cn";
import { sectionSlug } from "~/lib/text";

interface Props {
  count?: number;
  anchor?: boolean;
  class?: string;
}

const { count, anchor = false, class: className } = Astro.props;
const text = await Astro.slots.render("default");
const id = anchor && text ? sectionSlug(text) : undefined;
---

<h2
  id={id}
  data-section-anchor={id ?? undefined}
  class={cn(
    "group flex items-baseline gap-2 text-xs font-semibold uppercase tracking-[0.08em] text-ink-500 scroll-mt-20",
    className,
  )}
>
  <span>{text}</span>
  {count !== undefined && count > 0 && (
    <span class="rounded-full bg-sand-100 px-1.5 py-0.5 font-mono text-[10px] text-ink-500">
      {count}
    </span>
  )}
  {id && (
    <a
      href={`#${id}`}
      aria-label={`Link to ${text}`}
      class="text-ink-300 opacity-0 transition hover:text-accent-600 group-hover:opacity-100 print:hidden"
    >
      <span aria-hidden>#</span>
    </a>
  )}
</h2>
