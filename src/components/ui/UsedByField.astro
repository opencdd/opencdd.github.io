---
import Field from "./Field.astro";
import FilterableEntityList from "~/components/islands/FilterableEntityList.vue";
import { toEntityListItems } from "~/lib/listItems";
import type { DictionaryBundle } from "~/lib/bundle";
import type { EntityNode } from "~/lib/types";

interface Props {
  label: string;
  slug: string;
  bundle: DictionaryBundle;
  entities: readonly EntityNode[];
  exceptIrdi?: string;
}

const { label, slug, bundle, entities, exceptIrdi } = Astro.props;
const filtered = exceptIrdi
  ? entities.filter((e) => e.irdi !== exceptIrdi)
  : entities;
const items = toEntityListItems(
  filtered.map((e) => e.irdi),
  bundle,
  slug,
);
---

{filtered.length > 0 && (
  <Field label={`${label} (${filtered.length})`}>
    <FilterableEntityList client:visible items={items} />
  </Field>
)}
