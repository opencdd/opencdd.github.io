---
import { cn } from "~/lib/cn";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div
  aria-hidden="true"
  class={cn("relative overflow-hidden rounded-md bg-sand-200/70", className)}
>
  <div class="absolute inset-0 animate-pulse bg-gradient-to-r from-transparent via-white/50 to-transparent"></div>
</div>
