---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="flex flex-col items-center justify-center rounded-xl border border-dashed border-ink-200 bg-paper-50/60 px-6 py-10 text-center">
  <p class="text-sm font-medium text-ink-700">{title}</p>
  <p class="mt-1 max-w-sm text-xs text-ink-500">
    <slot />
  </p>
</div>
