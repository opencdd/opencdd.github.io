---
import type { DictionaryBundle } from "~/lib/bundle";
import type { EntityNode } from "~/lib/types";
import { codeFromIrdi } from "~/lib/irdi";
import { entityRoute, detailableTypeOf } from "~/lib/entityTypeMeta";

interface Props {
  slug: string;
  irdis: readonly string[];
  bundle: DictionaryBundle;
  empty?: string;
}

const { slug, irdis, bundle, empty = "—" } = Astro.props;

function resolve(irdi: string) {
  const node = bundle.find(irdi) as EntityNode | undefined;
  const type = node?.type ?? null;
  const detailable = type ? detailableTypeOf({ type, irdi } as EntityNode) : null;
  const code = node?.code ?? codeFromIrdi(irdi);
  const name = node?.preferred_name ?? code;
  const href = detailable ? entityRoute(slug, detailable, code) : null;
  return { irdi, code, name, href, resolved: !!node };
}
---

{irdis.length === 0 ? (
  <span class="text-sm text-ink-400">{empty}</span>
) : (
  <ul class="grid gap-1.5 sm:grid-cols-2">
    {irdis.map((irdi) => {
      const r = resolve(irdi);
      return (
        <li>
          {r.href ? (
            <a
              href={r.href}
              class="group flex items-center gap-2.5 rounded-lg border border-paper-200 bg-paper-50 px-3 py-2 transition hover:border-lapis-300 hover:bg-lapis-50/30 hover:shadow-xs"
            >
              <code class="shrink-0 rounded bg-paper-100 px-1.5 py-0.5 font-mono text-[10px] tracking-wide text-ink-500 transition group-hover:bg-lapis-100 group-hover:text-lapis-700">
                {r.code}
              </code>
              <span class="min-w-0 flex-1 truncate text-sm text-ink-800 transition group-hover:text-lapis-700">
                {r.name}
              </span>
            </a>
          ) : (
            <span
              class="flex items-center gap-2.5 rounded-lg border border-dashed border-amber-200 bg-amber-50/50 px-3 py-2"
              title={`IRDI ${irdi} — entity not present in browser data`}
            >
              <code class="shrink-0 rounded bg-amber-100 px-1.5 py-0.5 font-mono text-[10px] tracking-wide text-amber-700">
                {r.code}
              </code>
              <span class="min-w-0 flex-1 truncate text-sm italic text-ink-500">
                record not scraped
              </span>
            </span>
          )}
        </li>
      );
    })}
  </ul>
)}
