---
import EntityLink from "./EntityLink.astro";
import type { DictionaryBundle } from "~/lib/bundle";

interface Props {
  slug: string;
  irdis: readonly string[];
  bundle: DictionaryBundle;
  empty?: string;
}

const { slug, irdis, bundle, empty = "—" } = Astro.props;
---

{irdis.length === 0 ? (
  <span class="text-ink-400">{empty}</span>
) : (
  <ul class="flex flex-wrap gap-x-4 gap-y-1.5">
    {irdis.map((irdi) => (
      <li>
        <EntityLink slug={slug} irdi={irdi} bundle={bundle} />
      </li>
    ))}
  </ul>
)}
