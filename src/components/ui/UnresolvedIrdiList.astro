---
import { codeFromIrdi } from "~/lib/irdi";

interface Props {
  irdis: readonly string[];
  label?: string;
  tone?: "amber" | "rose";
}

const {
  irdis,
  label = "References not in browser data",
  tone = "amber",
} = Astro.props;

const containerClass =
  tone === "rose"
    ? "border-rose-300 bg-rose-50/40"
    : "border-amber-300 bg-amber-50/40";
const pillClass =
  tone === "rose"
    ? "border-rose-300 bg-rose-50 text-rose-700"
    : "border-amber-300 bg-amber-50 text-amber-700";
---

{irdis.length > 0 && (
  <div class={`mt-3 rounded-lg border px-3 py-2.5 ${containerClass}`}>
    <div class="flex items-center gap-2">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" class={`h-4 w-4 shrink-0 ${tone === "rose" ? "text-rose-500" : "text-amber-500"}`} aria-hidden="true">
        <path d="M8 4v5M8 11.5v.5" stroke-linecap="round"/>
        <circle cx="8" cy="8" r="6.5"/>
      </svg>
      <p class={`text-xs font-semibold ${tone === "rose" ? "text-rose-800" : "text-amber-800"}`}>
        {label} ({irdis.length})
      </p>
    </div>
    <ul class="mt-2 flex flex-wrap gap-1">
      {irdis.map((irdi) => (
        <li
          class={`inline-flex items-center gap-1 rounded border px-1.5 py-0.5 font-mono text-[10px] ${pillClass}`}
          title={`IRDI ${irdi} — referenced in the source data but entity record not available.`}
        >
          <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" class="h-2.5 w-2.5 opacity-60" aria-hidden="true">
            <line x1="1" y1="1" x2="11" y2="11" stroke-linecap="round"/>
          </svg>
          {codeFromIrdi(irdi)}
        </li>
      ))}
    </ul>
    <p class={`mt-2 text-[10px] ${tone === "rose" ? "text-rose-600/80" : "text-amber-600/80"}`}>
      These IRDIs appear in the source data but their full records weren't scraped.
    </p>
  </div>
)}
