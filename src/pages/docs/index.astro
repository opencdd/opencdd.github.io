---
import { getCollection, render } from "astro:content";
import DocsLayout from "~/layouts/DocsLayout.astro";

const entries = await getCollection("docs");
const indexEntry = entries.find((e) => e.id === "index" || e.id === "index.mdx");

if (!indexEntry) {
  throw new Error("Missing docs index: src/content/docs/index.mdx");
}

const { Content } = await render(indexEntry);

const docsNav = entries
  .filter((d) => d.id !== indexEntry.id)
  .map((d) => ({
    href: `/docs/${d.id.replace(/\.mdx$/, "")}/`,
    title: d.data.title,
    order: d.data.order ?? 0,
  }));
---

<DocsLayout
  title={indexEntry.data.title}
  description={indexEntry.data.description}
  docsNav={docsNav}
>
  <Content />
</DocsLayout>
