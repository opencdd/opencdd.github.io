---
import DictionaryLayout from "~/layouts/DictionaryLayout.astro";
import SectionTitle from "~/components/ui/SectionTitle.astro";
import EntityBrowser from "~/components/islands/EntityBrowser.vue";
import type { EntityTab } from "~/components/islands/EntityBrowser.vue";
import {
  TABBABLE_TYPES,
  entityPluralTitleFor,
  countForType,
  routeSegmentFor,
  entityTypeForSegment,
} from "~/lib/entityTypeMeta";
import { loadDictionary, listRegistryEntries } from "~/lib/data";
import { codeFromIrdi } from "~/lib/irdi";

export function getStaticPaths() {
  return listRegistryEntries().map((entry) => ({
    params: { dict: entry.slug },
  }));
}

const { dict } = Astro.params;
const bundle = loadDictionary(dict!);
const registry = bundle.registry;

const initialTabParam = Astro.url.searchParams.get("tab");
const initialTab = entityTypeForSegment(initialTabParam) ?? "class";

const tabs: EntityTab[] = TABBABLE_TYPES.map((type) => {
  const count = countForType(bundle, type);
  if (count === 0) return null;
  const segment = routeSegmentFor(type);
  const items = bundle.entitiesOfType(type).map((node) => {
    const code = node.code ?? codeFromIrdi(node.irdi);
    return {
      code,
      name: node.preferred_name ?? code,
      href: `/d/${dict}/${segment}/${code}/`,
    };
  });
  return {
    type,
    label: entityPluralTitleFor(type),
    count,
    items,
  };
}).filter((t): t is EntityTab => t !== null);
---

<DictionaryLayout
  dict={dict!}
  title={`${registry.title} — OpenCDD`}
  description={`Browse ${registry.title} — ${registry.parcelId}`}
>
  <div class="space-y-6">
    <header class="space-y-2">
      <p class="text-xs font-medium uppercase tracking-wide text-ink-500">
        Dictionary overview
      </p>
      <h1 class="text-3xl font-semibold tracking-tight text-ink-900">{registry.title}</h1>
      <p class="text-sm text-ink-600">
        Source language: <code class="font-mono text-xs">{registry.sourceLanguage}</code>
        {registry.translationLanguages.length > 0 && (
          <>
            {" "}· Translations:{" "}
            <code class="font-mono text-xs">{registry.translationLanguages.join(", ")}</code>
          </>
        )}
      </p>
      <p class="text-sm">
        <a
          href={`/d/${dict}/about`}
          class="text-hex-700 underline decoration-dotted underline-offset-2"
        >
          About this dictionary →
        </a>
      </p>
    </header>

    <div>
      <SectionTitle count={tabs.reduce((s, t) => s + t.count, 0)}>
        Browse entities
      </SectionTitle>
      <div class="mt-4">
        <EntityBrowser client:visible tabs={tabs} initialTab={initialTab} />
      </div>
    </div>
  </div>
</DictionaryLayout>
