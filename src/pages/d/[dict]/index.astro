---
import DictionaryLayout from "~/layouts/DictionaryLayout.astro";
import SectionTitle from "~/components/ui/SectionTitle.astro";
import EntityBrowser from "~/components/islands/EntityBrowser.vue";
import type { EntityTab } from "~/components/islands/EntityBrowser.vue";
import DictionaryDownloads from "~/components/ui/DictionaryDownloads.astro";
import {
  TABBABLE_TYPES,
  entityPluralTitleFor,
  countForType,
  routeSegmentFor,
  entityTypeForSegment,
} from "~/lib/entityTypeMeta";
import { loadDictionary, listRegistryEntries } from "~/lib/data";
import { codeFromIrdi } from "~/lib/irdi";

const MAX_ITEMS_PER_TAB = 200;

export function getStaticPaths() {
  return listRegistryEntries().map((entry) => ({
    params: { dict: entry.slug },
  }));
}

const { dict } = Astro.params;
const bundle = loadDictionary(dict!);
const registry = bundle.registry;

const initialTabParam = Astro.url.searchParams.get("tab");
const initialTab = entityTypeForSegment(initialTabParam) ?? "class";

const tabs: EntityTab[] = TABBABLE_TYPES.map((type) => {
  const totalCount = countForType(bundle, type);
  if (totalCount === 0) return null;
  const segment = routeSegmentFor(type);
  const allNodes = bundle.entitiesOfType(type);
  const cappedNodes = allNodes.slice(0, MAX_ITEMS_PER_TAB);
  const items = cappedNodes.map((node) => {
    const code = node.code ?? codeFromIrdi(node.irdi);
    return {
      code,
      name: node.preferred_name ?? code,
      href: `/d/${dict}/${segment}/${code}/`,
    };
  });
  return {
    type,
    label: entityPluralTitleFor(type),
    count: totalCount,
    items,
    totalCount,
  };
}).filter((t): t is EntityTab => t !== null);

const totalEntities = tabs.reduce((s, t) => s + t.count, 0);
const multiVersionEntities = TABBABLE_TYPES.reduce((sum, type) => {
  return sum + bundle.entitiesOfType(type).filter(
    (e) => (e.version_history?.length ?? 0) > 1,
  ).length;
}, 0);
---

<DictionaryLayout
  dict={dict!}
  title={`${registry.title} — OpenCDD`}
  description={`Browse ${registry.title} — ${registry.parcelId}`}
>
  <div class="space-y-6">
    <header class="space-y-2">
      <p class="text-xs font-medium uppercase tracking-wide text-ink-500">
        Dictionary overview
      </p>
      <h1 class="text-3xl font-semibold tracking-tight text-ink-900">{registry.title}</h1>
      <p class="text-sm text-ink-600">
        Source language: <code class="font-mono text-xs">{registry.sourceLanguage}</code>
        {registry.translationLanguages.length > 0 && (
          <>
            {" "}· Translations:{" "}
            <code class="font-mono text-xs">{registry.translationLanguages.join(", ")}</code>
          </>
        )}
      </p>
      <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm">
        <a
          href={`/d/${dict}/about`}
          class="text-hex-700 underline decoration-dotted underline-offset-2"
        >
          About this dictionary →
        </a>
        <a
          href={`/d/${dict}/changes/`}
          class="text-lapis-700 underline decoration-dotted underline-offset-2"
        >
          Recent version changes ({multiVersionEntities.toLocaleString()}) →
        </a>
      </div>
    </header>

    <div>
      <SectionTitle count={totalEntities}>
        Browse entities
      </SectionTitle>

      <!-- Quick-access browse-by-type links -->
      <div class="mt-3 flex flex-wrap gap-2">
        {tabs.map((tab) => (
          <a
            href={`/d/${dict}/browse/${tab.type === "class" ? "c" : tab.type === "property" ? "p" : tab.type === "unit" ? "u" : tab.type === "value_list" ? "v" : tab.type === "value_term" ? "t" : "r"}/`}
            class="inline-flex items-center gap-1.5 rounded-full border border-paper-200 bg-paper-50 px-3 py-1 text-xs font-medium text-ink-600 transition hover:border-lapis-300 hover:bg-lapis-50/30 hover:text-lapis-700"
          >
            {tab.label}{" "}
            <span class="font-mono text-[10px] text-ink-400">{tab.count.toLocaleString()}</span>
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" class="h-3 w-3 opacity-50">
              <path d="M4 3l5 5-5 5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        ))}
      </div>

      <div class="mt-4">
        <EntityBrowser client:visible tabs={tabs} initialTab={initialTab} />
      </div>
    </div>

    <DictionaryDownloads
      dict={dict!}
      parcelId={registry.parcelId}
      totalEntities={totalEntities}
      multiVersionEntities={multiVersionEntities}
    />
  </div>
</DictionaryLayout>
