---
import DictionaryLayout from "~/layouts/DictionaryLayout.astro";
import Card from "~/components/ui/Card.astro";
import EntityHero from "~/components/ui/EntityHero.astro";
import TableOfContents from "~/components/islands/TableOfContents.vue";
import MobileTOC from "~/components/islands/MobileTOC.vue";
import EntityBadge from "~/components/ui/EntityBadge.astro";
import Badge from "~/components/ui/Badge.astro";
import Breadcrumbs from "~/components/ui/Breadcrumbs.astro";
import FilterableEntityList from "~/components/islands/FilterableEntityList.vue";
import FilterablePropertyList from "~/components/islands/FilterablePropertyList.vue";
import ReferenceSection from "~/components/ui/ReferenceSection.astro";
import MetadataFields from "~/components/ui/MetadataFields.astro";
import RawProperties from "~/components/ui/RawProperties.astro";
import VersionHistorySection from "~/components/ui/VersionHistorySection.astro";
import DownloadMenu from "~/components/islands/DownloadMenu.vue";
import EntityGraphButton from "~/components/islands/EntityGraphButton.vue";
import ClassHierarchyDiagram from "~/components/ui/ClassHierarchyDiagram.astro";
import EmptyState from "~/components/ui/EmptyState.astro";
import { entityStaticPaths, loadEntityForPage } from "~/lib/entityPage";
import { codeFromIrdi } from "~/lib/irdi";
import { toEntityListItems, toPropertyListItems } from "~/lib/listItems";
import { buildClassPageData } from "~/lib/classPage";
import { computeEntityGraph } from "~/lib/entityGraph";
import type { ClassNode } from "~/lib/types";

export function getStaticPaths() {
  return entityStaticPaths("class");
}

const { dict } = Astro.params;
const { irdi } = Astro.props;
const { node, bundle } = loadEntityForPage<ClassNode>(dict!, irdi as string);

if (!node || node.type !== "class") {
  return Astro.redirect("/404/");
}

const page = buildClassPageData(node, bundle, dict!);

const higherLevelItems = toEntityListItems(
  page.higherLevel.map((c) => c.irdi),
  bundle,
  dict!,
);
const instanceItems = toEntityListItems(
  page.instances.map((c) => c.irdi),
  bundle,
  dict!,
);
const inheritedItems = toPropertyListItems(page.inherited, bundle, dict!);
const graph = computeEntityGraph(node.irdi, bundle, dict!, 2);
---

<DictionaryLayout
  dict={dict!}
  title={`${node.preferred_name ?? node.code} (${node.code}) — ${bundle.registry.title} — OpenCDD`}
>
  <Fragment slot="sidebar-right">
    <TableOfContents client:only="vue" />
  </Fragment>

  <article class="space-y-6">
    <Breadcrumbs
      slug={dict!}
      bundle={bundle}
      crumbs={page.ancestorCrumbs}
    />

    <MobileTOC client:only="vue" />

    <EntityHero
      title={node.preferred_name ?? node.code ?? codeFromIrdi(node.irdi)}
      irdi={node.irdi}
      definition={node.definition}
      titleTranslations={node.preferred_name_ml}
      definitionTranslations={node.definition_ml}
      shortName={node.short_name}
      version={node.version}
      revision={node.revision}
      dates={node.dates}
      sourceDocument={node.source_document}
      stats={page.stats}
    >
      <EntityBadge slot="badge" type="class" />
      <div slot="actions" class="flex items-center gap-2">
        <EntityGraphButton
          client:load
          nodes={graph.nodes}
          edges={graph.edges}
          centerIrdi={node.irdi}
          dict={dict!}
        />
        <DownloadMenu client:load entity={node} dict={dict!} />
      </div>
      {node.class_type && (
        <Badge slot="extra-badges" tone="violet">
          <span class="font-mono text-[10px]">{node.class_type}</span>
        </Badge>
      )}
    </EntityHero>

    <ClassHierarchyDiagram node={node} bundle={bundle} dict={dict!} />

    {page.higherLevel.length > 0 && (
      <ReferenceSection
        title="Higher level classes"
        count={page.higherLevel.length}
        anchor
        unresolved={page.unresolvedSuperclass}
        unresolvedLabel="Superclass (entity not scraped)"
        unresolvedTone="rose"
      >
        <FilterableEntityList client:visible items={higherLevelItems} />
      </ReferenceSection>
    )}

    <ReferenceSection
      title="Declared properties"
      count={page.declared.applicableCount}
      anchor
      unresolved={page.declared.unresolved}
      unresolvedLabel="Declared property references (entities not in browser data)"
    >
      {page.declared.properties.length === 0 ? (
        <EmptyState title={page.declared.applicableCount > 0 ? "Declared property records not in browser data" : "No declared properties"}>
          {page.declared.applicableCount > 0
            ? `${page.declared.applicableCount} property IRDIs are referenced but their full records weren't scraped. See the references list below.`
            : "This class does not declare any properties of its own."}
        </EmptyState>
      ) : (
        <FilterablePropertyList client:visible items={page.declared.items} />
      )}
    </ReferenceSection>

    {page.inherited.length > 0 && (
      <Card>
        <FilterablePropertyList
          client:visible
          items={inheritedItems}
          collapsable
          label="Inherited properties"
        />
      </Card>
    )}

    {page.imported.irdis.length > 0 && (
      <ReferenceSection
        title="Imported properties"
        count={page.imported.irdis.length}
        anchor
        unresolved={page.imported.unresolved}
        unresolvedLabel="Imported property references (entities not in browser data)"
      >
        {page.imported.irdis.length === page.imported.unresolved.length ? (
          <EmptyState title="Imported property records not in browser data" />
        ) : (
          <FilterableEntityList client:visible items={page.imported.items} placeholder="Filter imported properties…" />
        )}
      </ReferenceSection>
    )}

    <ReferenceSection title="Subclasses" count={page.subclasses.nodes.length} anchor>
      {page.subclasses.nodes.length === 0 ? (
        <EmptyState title="No subclasses">
          This class is a leaf — no other classes inherit from it.
        </EmptyState>
      ) : (
        <FilterableEntityList client:visible items={page.subclasses.items} placeholder="Filter subclasses…" />
      )}
    </ReferenceSection>

    {page.isCaseOf.irdis.length > 0 && (
      <ReferenceSection
        title="Is case of (powertype parents)"
        count={page.isCaseOf.irdis.length}
        anchor
        unresolved={page.isCaseOf.unresolved}
        unresolvedLabel="Is-case-of references (entities not in browser data)"
      >
        {page.isCaseOf.irdis.length === page.isCaseOf.unresolved.length ? (
          <EmptyState title="Powertype parent records not in browser data" />
        ) : (
          <FilterableEntityList client:visible items={page.isCaseOf.items} placeholder="Filter powertype parents…" />
        )}
      </ReferenceSection>
    )}

    {page.instances.length > 0 && (
      <ReferenceSection title="Instances (powertype)" count={page.instances.length} anchor>
        <FilterableEntityList client:visible items={instanceItems} />
      </ReferenceSection>
    )}

    {page.composition.irdis.length > 0 && (
      <ReferenceSection
        title="Composition (sub_class_selection)"
        count={page.composition.irdis.length}
        anchor
        unresolved={page.composition.unresolved}
        unresolvedLabel="Composition references (entities not in browser data)"
      >
        {page.composition.irdis.length === page.composition.unresolved.length ? (
          <EmptyState title="Composition target records not in browser data" />
        ) : (
          <FilterableEntityList client:visible items={page.composition.items} placeholder="Filter composition…" />
        )}
      </ReferenceSection>
    )}

    {page.relationsAsDomain.nodes.length > 0 && (
      <ReferenceSection title="Relations" count={page.relationsAsDomain.nodes.length} anchor>
        <FilterableEntityList client:visible items={page.relationsAsDomain.items} placeholder="Filter relations…" />
      </ReferenceSection>
    )}

    {page.relationsAsCodomain.nodes.length > 0 && (
      <ReferenceSection title="Referenced as codomain" count={page.relationsAsCodomain.nodes.length} anchor>
        <FilterableEntityList client:visible items={page.relationsAsCodomain.items} placeholder="Filter references…" />
      </ReferenceSection>
    )}

    <ReferenceSection title="Metadata" anchor>
      <MetadataFields entity={node} />
    </ReferenceSection>

    {node.raw_properties && Object.keys(node.raw_properties).length > 0 && (
      <ReferenceSection title="Full source data" anchor>
        <p class="text-xs text-ink-500">
          Every key from the original .xls export, including multilingual
          variants, status, publisher, committee, and workbook-specific
          codes.
        </p>
        <div class="mt-3">
          <RawProperties properties={node.raw_properties as Record<string, string>} />
        </div>
      </ReferenceSection>
    )}

    <VersionHistorySection entity={node} dict={dict!} />
  </article>
</DictionaryLayout>
