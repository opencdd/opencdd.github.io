---
import DictionaryLayout from "~/layouts/DictionaryLayout.astro";
import Card from "~/components/ui/Card.astro";
import SectionTitle from "~/components/ui/SectionTitle.astro";
import EntityHero from "~/components/ui/EntityHero.astro";
import TableOfContents from "~/components/islands/TableOfContents.vue";
import EntityBadge from "~/components/ui/EntityBadge.astro";
import Badge from "~/components/ui/Badge.astro";
import Breadcrumbs from "~/components/ui/Breadcrumbs.astro";
import EntityLinkList from "~/components/ui/EntityLinkList.astro";
import PropertyTable from "~/components/ui/PropertyTable.astro";
import MetadataFields from "~/components/ui/MetadataFields.astro";
import RawProperties from "~/components/ui/RawProperties.astro";
import EmptyState from "~/components/ui/EmptyState.astro";
import UnresolvedIrdiList from "~/components/ui/UnresolvedIrdiList.astro";
import { entityStaticPaths, loadEntityForPage } from "~/lib/entityPage";
import { codeFromIrdi } from "~/lib/irdi";
import type { ClassNode } from "~/lib/types";

export function getStaticPaths() {
  return entityStaticPaths("class");
}

const { dict } = Astro.params;
const { irdi } = Astro.props;
const { node, bundle } = loadEntityForPage<ClassNode>(dict!, irdi as string);

if (!node || node.type !== "class") {
  return Astro.redirect("/404/");
}

const subclasses = bundle.subclassesOf(node.irdi);
const instances = bundle.instancesOf(node.irdi);
const declared = bundle.propertiesByClassIrdi(node.irdi);
const effective = bundle.effectivePropertiesOf(node.irdi);
const declaredIrdiSet = new Set(declared.map((p) => p.irdi));
const inherited = effective.properties.filter((p) => !declaredIrdiSet.has(p.irdi));
const relationsAsDomain = bundle.relationsForClass(node.irdi);
const relationsAsCodomain = bundle.relationsForCodomainClass(node.irdi);
const ancestorChain = bundle.ancestorChainOf(node.irdi);

// Unresolved references — IRDIs the source data mentions but whose
// entities weren't scraped. Surface them visibly so the gap is
// explicit, instead of silently rendering "No X".
const applicableIrdis = node.applicable_properties ?? [];
const importedIrdis = node.imported_properties ?? [];
const isCaseOfIrdis = node.is_case_of ?? [];
const compositionIrdis = node.sub_class_selection ?? [];

const unresolvedDeclared = bundle.resolveIrdis(applicableIrdis).unresolved;
const unresolvedImported = bundle.resolveIrdis(importedIrdis).unresolved;
const unresolvedIsCaseOf = bundle.resolveIrdis(isCaseOfIrdis).unresolved;
const unresolvedComposition = bundle.resolveIrdis(compositionIrdis).unresolved;
const unresolvedSuperclass =
  node.superclass && !bundle.hasEntity(node.superclass) ? [node.superclass] : [];

// "Higher level classes" — the ancestor chain (Root → ... → Self).
// We exclude the entity itself from this listing (the last entry).
const higherLevel = ancestorChain.slice(0, -1);
---

<DictionaryLayout
  dict={dict!}
  title={`${node.preferred_name ?? node.code} (${node.code}) — ${bundle.registry.title} — OpenCDD`}
>
  <article class="space-y-6">
    <Breadcrumbs
      slug={dict!}
      bundle={bundle}
      crumbs={ancestorChain.map((c) => ({ irdi: c.irdi }))}
    />

    <div class="hidden lg:block rounded-lg border border-ink-200 bg-sand-50/50 px-3 py-2">
      <TableOfContents client:visible />
    </div>

    <EntityHero
      title={node.preferred_name ?? node.code ?? codeFromIrdi(node.irdi)}
      irdi={node.irdi}
      definition={node.definition}
      titleTranslations={node.preferred_name_ml}
      definitionTranslations={node.definition_ml}
      shortName={node.short_name}
      version={node.version}
      revision={node.revision}
      dates={node.dates}
      sourceDocument={node.source_document}
    >
      <EntityBadge slot="badge" type="class" />
      {node.class_type && (
        <Badge slot="extra-badges" tone="violet">
          <span class="font-mono text-[10px]">{node.class_type}</span>
        </Badge>
      )}
    </EntityHero>

    {higherLevel.length > 0 && (
      <Card>
        <SectionTitle count={higherLevel.length} anchor={true}>Higher level classes</SectionTitle>
        <div class="mt-3">
          <ol class="space-y-1 text-sm">
            {higherLevel.map((c) => (
              <li class="flex items-baseline gap-2">
                <EntityLinkList
                  slug={dict!}
                  bundle={bundle}
                  irdis={[c.irdi]}
                />
              </li>
            ))}
          </ol>
          {unresolvedSuperclass.length > 0 && (
            <UnresolvedIrdiList
              irdis={unresolvedSuperclass}
              label="Superclass (entity not scraped)"
              tone="rose"
            />
          )}
        </div>
      </Card>
    )}

    <Card>
      <SectionTitle count={applicableIrdis.length} anchor={true}>Declared properties</SectionTitle>
      <div class="mt-3">
        {declared.length === 0 ? (
          <EmptyState title={applicableIrdis.length > 0 ? "Declared property records not in browser data" : "No declared properties"}>
            {applicableIrdis.length > 0
              ? `${applicableIrdis.length} property IRDIs are referenced but their full records weren't scraped. See the references list below.`
              : "This class does not declare any properties of its own."}
          </EmptyState>
        ) : (
          <PropertyTable slug={dict!} bundle={bundle} properties={declared} />
        )}
        <UnresolvedIrdiList
          irdis={unresolvedDeclared}
          label="Declared property references (entities not in browser data)"
        />
      </div>
    </Card>

    {inherited.length > 0 && (
      <Card>
        <PropertyTable
          slug={dict!}
          bundle={bundle}
          properties={inherited}
          collapsable
          label="Inherited properties"
        />
      </Card>
    )}

    {importedIrdis.length > 0 && (
      <Card>
        <SectionTitle count={importedIrdis.length} anchor={true}>Imported properties</SectionTitle>
        <div class="mt-3">
          {importedIrdis.length === unresolvedImported.length ? (
            <EmptyState title="Imported property records not in browser data" />
          ) : (
            <EntityLinkList
              slug={dict!}
              bundle={bundle}
              irdis={importedIrdis}
              empty="No imported properties."
            />
          )}
          <UnresolvedIrdiList
            irdis={unresolvedImported}
            label="Imported property references (entities not in browser data)"
          />
        </div>
      </Card>
    )}

    <Card>
      <SectionTitle count={subclasses.length} anchor={true}>Subclasses</SectionTitle>
      <div class="mt-3">
        <EntityLinkList
          slug={dict!}
          bundle={bundle}
          irdis={subclasses.map((c) => c.irdi)}
          empty="No subclasses."
        />
      </div>
    </Card>

    {isCaseOfIrdis.length > 0 && (
      <Card>
        <SectionTitle count={isCaseOfIrdis.length} anchor={true}>Is case of (powertype parents)</SectionTitle>
        <div class="mt-3">
          {isCaseOfIrdis.length === unresolvedIsCaseOf.length ? (
            <EmptyState title="Powertype parent records not in browser data" />
          ) : (
            <EntityLinkList slug={dict!} bundle={bundle} irdis={isCaseOfIrdis} />
          )}
          <UnresolvedIrdiList
            irdis={unresolvedIsCaseOf}
            label="Is-case-of references (entities not in browser data)"
          />
        </div>
      </Card>
    )}

    {instances.length > 0 && (
      <Card>
        <SectionTitle count={instances.length} anchor={true}>Instances (powertype)</SectionTitle>
        <div class="mt-3">
          <EntityLinkList slug={dict!} bundle={bundle} irdis={instances.map((c) => c.irdi)} />
        </div>
      </Card>
    )}

    {compositionIrdis.length > 0 && (
      <Card>
        <SectionTitle count={compositionIrdis.length} anchor={true}>Composition (sub_class_selection)</SectionTitle>
        <div class="mt-3">
          {compositionIrdis.length === unresolvedComposition.length ? (
            <EmptyState title="Composition target records not in browser data" />
          ) : (
            <EntityLinkList slug={dict!} bundle={bundle} irdis={compositionIrdis} />
          )}
          <UnresolvedIrdiList
            irdis={unresolvedComposition}
            label="Composition references (entities not in browser data)"
          />
        </div>
      </Card>
    )}

    {relationsAsDomain.length > 0 && (
      <Card>
        <SectionTitle count={relationsAsDomain.length} anchor={true}>Relations</SectionTitle>
        <div class="mt-3">
          <ul class="space-y-1.5 text-sm">
            {relationsAsDomain.map((r) => (
              <li>
                <EntityLinkList slug={dict!} bundle={bundle} irdis={[r.irdi]} />
              </li>
            ))}
          </ul>
        </div>
      </Card>
    )}

    {relationsAsCodomain.length > 0 && (
      <Card>
        <SectionTitle count={relationsAsCodomain.length} anchor={true}>Referenced as codomain</SectionTitle>
        <div class="mt-3">
          <ul class="space-y-1.5 text-sm">
            {relationsAsCodomain.map((r) => (
              <li>
                <EntityLinkList slug={dict!} bundle={bundle} irdis={[r.irdi]} />
              </li>
            ))}
          </ul>
        </div>
      </Card>
    )}

    <Card>
      <SectionTitle anchor={true}>Metadata</SectionTitle>
      <div class="mt-3">
        <MetadataFields entity={node} />
      </div>
    </Card>

    {(node as any).raw_properties && (
      <Card>
        <SectionTitle anchor={true}>Full source data</SectionTitle>
        <p class="mt-2 text-xs text-ink-500">
          Every key from the original .xls export, including multilingual
          variants, status, publisher, committee, and workbook-specific
          codes. This is the raw, unprocessed content — nothing from the
          source is discarded.
        </p>
        <div class="mt-3">
          <RawProperties properties={(node as any).raw_properties} />
        </div>
      </Card>
    )}
  </article>
</DictionaryLayout>
