---
import EntityDetailShell from "~/layouts/EntityDetailShell.astro";
import Card from "~/components/ui/Card.astro";
import EntityBadge from "~/components/ui/EntityBadge.astro";
import Field from "~/components/ui/Field.astro";
import UsedByField from "~/components/ui/UsedByField.astro";
import { entityStaticPaths, loadEntityForPage } from "~/lib/entityPage";
import type { UnitNode } from "~/lib/types";

export function getStaticPaths() {
  return entityStaticPaths("unit");
}

const { dict } = Astro.params;
const { irdi } = Astro.props;
const { node, bundle } = loadEntityForPage<UnitNode>(dict!, irdi as string);

if (!node || node.type !== "unit") {
  return Astro.redirect("/404/");
}

const usedBy = bundle.propertiesForUnit(node.irdi);
---

<EntityDetailShell
  dict={dict!}
  node={node}
  title={`${node.preferred_name ?? node.code} — ${bundle.registry.title} — OpenCDD`}
>
  <EntityBadge slot="badge" type="unit" />

  <Card>
    <dl class="grid gap-3 sm:grid-cols-2">
      {node.symbol && (
        <Field label="Symbol">
          <code class="font-mono text-sm">{node.symbol}</code>
        </Field>
      )}
      {node.structure && (
        <Field label="Structure">
          <code class="font-mono text-xs">{node.structure}</code>
        </Field>
      )}
      {node.text_representation && (
        <Field label="Text representation">
          <code class="font-mono text-xs">{node.text_representation}</code>
        </Field>
      )}
    </dl>
  </Card>

  <UsedByField
    label="Used by properties"
    slug={dict!}
    bundle={bundle}
    entities={usedBy}
    exceptIrdi={node.irdi}
  />
</EntityDetailShell>
