---
import EntityDetailShell from "~/layouts/EntityDetailShell.astro";
import Card from "~/components/ui/Card.astro";
import EntityBadge from "~/components/ui/EntityBadge.astro";
import Field from "~/components/ui/Field.astro";
import EntityLink from "~/components/ui/EntityLink.astro";
import { entityStaticPaths, loadEntityForPage } from "~/lib/entityPage";
import type { ValueTermNode } from "~/lib/types";

export function getStaticPaths() {
  return entityStaticPaths("value_term");
}

const { dict } = Astro.params;
const { irdi } = Astro.props;
const { node, bundle } = loadEntityForPage<ValueTermNode>(dict!, irdi as string);

if (!node || node.type !== "value_term") {
  return Astro.redirect("/404/");
}
---

<EntityDetailShell
  dict={dict!}
  node={node}
  title={`${node.preferred_name ?? node.code} — ${bundle.registry.title} — OpenCDD`}
>
  <EntityBadge slot="badge" type="value_term" />

  <Card>
    <dl class="grid gap-3 sm:grid-cols-2">
      <Field label="Enumeration code">
        <code class="font-mono text-xs">{node.enumeration_code ?? node.code}</code>
      </Field>
      {node.value_list && (
        <Field label="Parent value list">
          <EntityLink slug={dict!} irdi={node.value_list} bundle={bundle} />
        </Field>
      )}
    </dl>
  </Card>
</EntityDetailShell>
