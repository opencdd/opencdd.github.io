---
import EntityDetailShell from "~/layouts/EntityDetailShell.astro";
import Card from "~/components/ui/Card.astro";
import EntityBadge from "~/components/ui/EntityBadge.astro";
import Field from "~/components/ui/Field.astro";
import FilterableEntityList from "~/components/islands/FilterableEntityList.vue";
import EntityLink from "~/components/ui/EntityLink.astro";
import { entityStaticPaths, loadEntityForPage } from "~/lib/entityPage";
import { toEntityListItems } from "~/lib/listItems";
import type { RelationNode } from "~/lib/types";

export function getStaticPaths() {
  return entityStaticPaths("relation");
}

const { dict } = Astro.params;
const { irdi } = Astro.props;
const { node, bundle } = loadEntityForPage<RelationNode>(dict!, irdi as string);

if (!node || node.type !== "relation") {
  return Astro.redirect("/404/");
}

const domainItems = node.domain
  ? toEntityListItems(node.domain, bundle, dict!)
  : [];
---

<EntityDetailShell
  dict={dict!}
  node={node}
  title={`${node.preferred_name ?? node.code} — ${bundle.registry.title} — OpenCDD`}
>
  <EntityBadge slot="badge" type="relation" />

  <Card>
    <dl class="grid gap-3 sm:grid-cols-2">
      {node.relation_type && (
        <Field label="Relation type">
          <code class="font-mono text-xs">{node.relation_type}</code>
        </Field>
      )}
      {node.role && (
        <Field label="Role">
          {node.role}
        </Field>
      )}
      {node.segment && (
        <Field label="Segment">
          {node.segment}
        </Field>
      )}
      <Field label="Domain">
        {domainItems.length > 0 ? (
          <FilterableEntityList client:visible items={domainItems} />
        ) : (
          <span class="text-ink-400">—</span>
        )}
      </Field>
      <Field label="Codomain">
        {node.codomain ? (
          <EntityLink slug={dict!} irdi={node.codomain} bundle={bundle} />
        ) : (
          <span class="text-ink-400">—</span>
        )}
      </Field>
      {node.formula && (
        <Field label="Formula">
          <code class="font-mono text-xs">{node.formula}</code>
        </Field>
      )}
      {node.formula_language && (
        <Field label="Formula language">
          {node.formula_language}
        </Field>
      )}
    </dl>
  </Card>
</EntityDetailShell>
