---
import EntityDetailShell from "~/layouts/EntityDetailShell.astro";
import ReferenceSection from "~/components/ui/ReferenceSection.astro";
import EntityBadge from "~/components/ui/EntityBadge.astro";
import FilterableValueTermList from "~/components/islands/FilterableValueTermList.vue";
import UsedByField from "~/components/ui/UsedByField.astro";
import { entityStaticPaths, loadEntityForPage } from "~/lib/entityPage";
import { toValueTermListItems } from "~/lib/listItems";
import type { ValueListNode, ValueTermNode } from "~/lib/types";

export function getStaticPaths() {
  return entityStaticPaths("value_list");
}

const { dict } = Astro.params;
const { irdi } = Astro.props;
const { node, bundle } = loadEntityForPage<ValueListNode>(dict!, irdi as string);

if (!node || node.type !== "value_list") {
  return Astro.redirect("/404/");
}

const usedBy = bundle.propertiesForValueList(node.irdi);

let terms: readonly ValueTermNode[] = [];
if (node.term_irdis && node.term_irdis.length > 0) {
  terms = node.term_irdis
    .map((i) => bundle.find(i))
    .filter((n): n is ValueTermNode => !!n && n.type === "value_term");
} else {
  terms = (bundle.entitiesOfType("value_term")).filter(
    (n): n is ValueTermNode => n.type === "value_term" && n.value_list === node.irdi,
  );
}

const termItems = toValueTermListItems(terms, dict!);
---

<EntityDetailShell
  dict={dict!}
  node={node}
  title={`${node.preferred_name ?? node.code} — ${bundle.registry.title} — OpenCDD`}
>
  <EntityBadge slot="badge" type="value_list" />

  {terms.length > 0 && (
    <ReferenceSection title="Terms" count={terms.length} anchor>
      <FilterableValueTermList client:visible items={termItems} empty="No terms." />
    </ReferenceSection>
  )}

  <UsedByField
    label="Used by properties"
    slug={dict!}
    bundle={bundle}
    entities={usedBy}
    exceptIrdi={node.irdi}
  />
</EntityDetailShell>
