---
import DictionaryLayout from "~/layouts/DictionaryLayout.astro";
import Card from "~/components/ui/Card.astro";
import SectionTitle from "~/components/ui/SectionTitle.astro";
import Field from "~/components/ui/Field.astro";
import {
  ENTITY_TYPE_ORDER,
  TABBABLE_TYPES,
  entityPluralTitleFor,
  countForType,
} from "~/lib/entityTypeMeta";
import { listDictionarySlugs, loadDictionary } from "~/lib/data";
import { findDictionary } from "~/lib/dictionary";

export function getStaticPaths() {
  return listDictionarySlugs().map((slug) => ({
    params: { dict: slug },
  }));
}

const { dict } = Astro.params;
const bundle = loadDictionary(dict!);
const info = findDictionary(dict!);
if (!info) {
  return Astro.redirect("/404/");
}
---

<DictionaryLayout
  dict={dict!}
  title={`About ${info.shortTitle} — OpenCDD`}
>
  <div class="space-y-6">
    <header class="space-y-2">
      <div class="flex flex-wrap items-center gap-2">
        <p class="text-xs font-medium uppercase tracking-wide text-ink-500">
          About this dictionary
        </p>
        {info.demonstration === true && (
          <span class="rounded-full bg-amber-50 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-amber-700">
            Demonstration fixture
          </span>
        )}
      </div>
      <h1 class="text-3xl font-semibold tracking-tight text-ink-900">{info.title}</h1>
      {!info.demonstration && (
        <p class="text-sm text-ink-500">
          {info.publicationId}
          {info.publishedYear && ` · ${info.publishedYear}`}
          {info.technicalCommittee && ` · ${info.technicalCommittee}`}
        </p>
      )}
    </header>

    {info.abstract && (
      <Card>
        <SectionTitle>Abstract</SectionTitle>
        <p class="mt-3 text-sm leading-relaxed text-ink-700">{info.abstract}</p>
        {info.webstoreUrl && (
          <p class="mt-3 text-xs text-ink-500">
            Canonical publication:{" "}
            <a
              href={info.webstoreUrl}
              class="text-accent-700 underline underline-offset-2"
              >{info.publicationId}</a
            >
            on the IEC webstore (© IEC, Geneva).
          </p>
        )}
      </Card>
    )}

    <Card>
      <SectionTitle>Dictionary metadata</SectionTitle>
      <dl class="mt-3 grid gap-3 sm:grid-cols-2">
        <Field label="Publication ID">
          <code class="font-mono text-sm">{info.publicationId}</code>
        </Field>
        {info.edition && (
          <Field label="Edition">
            <code class="font-mono text-sm">{info.edition}</code>
          </Field>
        )}
        <Field label="Parcel ID">
          <code class="font-mono text-sm">{info.parcelId}</code>
        </Field>
        <Field label="Slug">
          <code class="font-mono text-sm">{info.slug}</code>
        </Field>
        <Field label="Source language">
          <code class="font-mono text-sm">{info.sourceLanguage}</code>
        </Field>
        {info.translationLanguages.length > 0 && (
          <Field label="Translation languages">
            {info.translationLanguages.join(", ")}
          </Field>
        )}
        {info.technicalCommittee && (
          <Field label="Technical committee">
            <span class="text-sm text-ink-700">{info.technicalCommittee}</span>
          </Field>
        )}
        {info.metaClassIrdis.length > 0 && (
          <Field label="Meta-class IRDIs">
            <ul class="space-y-0.5">
              {info.metaClassIrdis.map((irdi) => (
                <li>
                  <code class="font-mono text-xs">{irdi}</code>
                </li>
              ))}
            </ul>
          </Field>
        )}
      </dl>
    </Card>

    <Card>
      <SectionTitle>Entity inventory</SectionTitle>
      <table class="mt-3 min-w-full text-sm">
        <thead>
          <tr class="border-b border-ink-200 text-left text-xs uppercase tracking-wide text-ink-500">
            <th class="px-3 py-2 font-medium">Type</th>
            <th class="px-3 py-2 font-medium text-right">Count</th>
            <th class="px-3 py-2 font-medium">Browse</th>
          </tr>
        </thead>
        <tbody>
          {ENTITY_TYPE_ORDER.map((type) => {
            const count = countForType(bundle, type);
            if (count === 0) return null;
            const canBrowse = TABBABLE_TYPES.includes(type);
            return (
              <tr class="border-b border-ink-100">
                <td class="px-3 py-2 font-medium text-ink-800">
                  {entityPluralTitleFor(type)}
                </td>
                <td class="px-3 py-2 text-right font-mono text-xs text-ink-600">{count}</td>
                <td class="px-3 py-2 text-sm">
                  {canBrowse ? (
                    <a
                      href={`/d/${dict}/?tab=${type}`}
                      class="text-accent-700 underline decoration-dotted underline-offset-2"
                    >
                      Browse list →
                    </a>
                  ) : (
                    <span class="text-ink-300">—</span>
                  )}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </Card>
  </div>
</DictionaryLayout>
