---
import DictionaryLayout from "~/layouts/DictionaryLayout.astro";
import Card from "~/components/ui/Card.astro";
import SectionTitle from "~/components/ui/SectionTitle.astro";
import EntityBadge from "~/components/ui/EntityBadge.astro";
import Badge from "~/components/ui/Badge.astro";
import EmptyState from "~/components/ui/EmptyState.astro";
import { loadDictionary, listRegistryEntries } from "~/lib/data";
import { recentChanges, groupByMonth } from "~/lib/recentChanges";

export function getStaticPaths() {
  return listRegistryEntries().map((entry) => ({
    params: { dict: entry.slug },
  }));
}

const { dict } = Astro.params;
const bundle = loadDictionary(dict!);
const registry = bundle.registry;
const rows = recentChanges(bundle, dict!, 500);
const groups = groupByMonth(rows);
const multiVersionCount = rows.filter((r) => !r.isCurrent).length;
---

<DictionaryLayout
  dict={dict!}
  title={`Recent changes — ${registry.title} — OpenCDD`}
>
  <article class="space-y-6">
    <header class="space-y-2">
      <p class="text-xs font-medium uppercase tracking-wide text-ink-500">
        Version history · aggregated
      </p>
      <h1 class="text-3xl font-semibold tracking-tight text-ink-900">
        Recent changes
      </h1>
      <p class="text-sm text-ink-600">
        {rows.length.toLocaleString()} version entries across {multiVersionCount.toLocaleString()} historical versions.
        Sorted reverse-chronologically. Capped at 500 most recent.
      </p>
      <p>
        <a
          href={`/d/${dict}/`}
          class="text-hex-700 text-sm underline decoration-dotted underline-offset-2"
        >
          ← Back to {registry.title}
        </a>
      </p>
    </header>

    {groups.length === 0 ? (
      <EmptyState title="No version history">
        None of the entities in this dictionary carry published version stamps.
      </EmptyState>
    ) : (
      <div class="space-y-5">
        {groups.map((group) => (
          <section>
            <SectionTitle count={group.rows.length}>
              {group.monthLabel}
            </SectionTitle>
            <Card pad={false} class="mt-3 overflow-hidden">
              <ul role="list" class="divide-y divide-paper-200">
                {group.rows.map((row) => (
                  <li class="flex flex-wrap items-baseline gap-x-3 gap-y-1 px-4 py-2.5 hover:bg-paper-100/60 transition">
                    <span class="font-mono text-[11px] text-ink-500 tabular-nums">
                      {row.timestamp?.slice(0, 10) ?? "—"}
                    </span>
                    <Badge tone={row.isCurrent ? "accent" : "neutral"}>
                      {row.isCurrent ? "current" : (row.status ?? "version")}
                    </Badge>
                    <span class="text-[11px] text-ink-500">
                      v{row.version ?? "?"}
                      {row.revision && row.revision !== "01" && ` rev ${row.revision}`}
                    </span>
                    <EntityBadge type={row.type} />
                    <a
                      href={row.href}
                      class="font-mono text-xs text-lapis-700 underline decoration-dotted underline-offset-2 transition hover:text-lapis-900"
                    >
                      {row.code}
                    </a>
                    <span class="text-sm text-ink-700">{row.name}</span>
                    {row.user && (
                      <span class="ml-auto text-[11px] text-ink-500">
                        by <code class="font-mono">{row.user}</code>
                      </span>
                    )}
                    {row.changeRequestId && (
                      <span class="text-[11px] text-ink-500">
                        CR <code class="font-mono">{row.changeRequestId}</code>
                      </span>
                    )}
                  </li>
                ))}
              </ul>
            </Card>
          </section>
        ))}
      </div>
    )}
  </article>
</DictionaryLayout>
