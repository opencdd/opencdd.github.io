---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Card from "~/components/ui/Card.astro";
import SectionTitle from "~/components/ui/SectionTitle.astro";
import Badge from "~/components/ui/Badge.astro";
import { computeSiteStats, topTypes } from "~/lib/siteStats";
import { TABBABLE_TYPES, entityPluralTitleFor } from "~/lib/entityTypeMeta";

const stats = computeSiteStats();
const top = topTypes(stats, TABBABLE_TYPES.length);
const maxDictEntities = Math.max(...stats.perDictionary.map((d) => d.totalEntities));
const entityIconHref = (type: string): string => {
  const icons: Record<string, string> = {
    class: "M3 2.75A1.75 1.75 0 0 1 4.75 1h6.5A1.75 1.75 0 0 1 13 2.75v10.5A1.75 1.75 0 0 1 11.25 15h-6.5A1.75 1.75 0 0 1 3 13.25V2.75Z",
    property: "M5 1a2 2 0 0 0-2 2v1h2V3h6v10H5v-1H3v1a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2H5Z",
    value_list: "M4 4h8v2H4zM4 7h8v2H4zM4 10h8v2H4z",
    value_term: "M5 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2H5Z",
    unit: "M8 1a.75.75 0 0 1 .75.75v6.94l2.22-2.22a.75.75 0 1 1 1.06 1.06l-3.5 3.5a.75.75 0 0 1-1.06 0l-3.5-3.5a.75.75 0 1 1 1.06-1.06l2.22 2.22V1.75A.75.75 0 0 1 8 1Z",
    relation: "M1 5.25A2.25 2.25 0 0 1 3.25 3h9.5A2.25 2.25 0 0 1 15 5.25v5.5A2.25 2.25 0 0 1 12.75 13h-9.5A2.25 2.25 0 0 1 1 10.75v-5.5Z",
    view_control: "M8 1a7 7 0 1 0 7 7A7 7 0 0 0 8 1Z",
  };
  return icons[type] ?? icons.class! ?? "";
};
---

<BaseLayout
  title="Stats — OpenCDD"
  description="OpenCDD site-wide statistics"
>
  <article class="mx-auto max-w-5xl space-y-8 px-6 py-10">
    <header class="space-y-2">
      <p class="text-xs font-medium uppercase tracking-wide text-ink-500">
        Site-wide statistics
      </p>
      <h1 class="font-display text-4xl text-ink-900">
        {stats.totalEntities.toLocaleString()} entities
      </h1>
      <p class="text-sm text-ink-600">
        across {stats.totalDictionaries} IEC CDD dictionaries · {stats.totalVersions.toLocaleString()} total version entries · {stats.multiVersionEntities.toLocaleString()} multi-version entities
      </p>
    </header>

    <section>
      <SectionTitle>Entities by type</SectionTitle>
      <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {top.map((t) => {
          const pct = stats.totalEntities > 0 ? Math.round((t.count / stats.totalEntities) * 100) : 0;
          return (
            <Card>
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <span class="flex h-8 w-8 items-center justify-center rounded-md bg-paper-200 text-ink-700">
                    <svg viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4" aria-hidden="true">
                      <path d={entityIconHref(t.type)} />
                    </svg>
                  </span>
                  <span class="text-sm font-semibold text-ink-800">{t.label}</span>
                </div>
                <span class="font-mono text-sm tabular-nums text-ink-700">{t.count.toLocaleString()}</span>
              </div>
              <div class="mt-3 h-1.5 overflow-hidden rounded-full bg-paper-200">
                <div class="h-full bg-hex-400" style={`width: ${pct}%`}></div>
              </div>
              <p class="mt-1 text-[11px] text-ink-500">{pct}% of all entities</p>
            </Card>
          );
        })}
      </div>
    </section>

    <section>
      <SectionTitle>Dictionaries by size</SectionTitle>
      <Card pad={false} class="mt-4 overflow-hidden">
        <ul role="list" class="divide-y divide-paper-200">
          {stats.perDictionary.map((d) => {
            const pct = maxDictEntities > 0 ? Math.round((d.totalEntities / maxDictEntities) * 100) : 0;
            return (
              <li class="px-4 py-3 hover:bg-paper-100/60 transition">
                <div class="flex items-baseline justify-between gap-3">
                  <a
                    href={`/d/${d.slug}/`}
                    class="text-sm font-medium text-ink-900 underline decoration-dotted underline-offset-2 hover:text-lapis-700"
                  >
                    {d.title}
                  </a>
                  <span class="font-mono text-xs tabular-nums text-ink-700">
                    {d.totalEntities.toLocaleString()} entities
                  </span>
                </div>
                <div class="mt-2 flex items-center gap-2">
                  <div class="h-1 flex-1 overflow-hidden rounded-full bg-paper-200">
                    <div class="h-full bg-teal-400" style={`width: ${pct}%`}></div>
                  </div>
                  {d.multiVersionEntities > 0 && (
                    <Badge tone="accent">
                      {d.multiVersionEntities.toLocaleString()} multi-version
                    </Badge>
                  )}
                </div>
                <p class="mt-1.5 text-[11px] text-ink-500">
                  {TABBABLE_TYPES.filter((t) => d.byType[t]).map((t) => `${entityPluralTitleFor(t)}: ${(d.byType[t] ?? 0).toLocaleString()}`).join(" · ")}
                </p>
              </li>
            );
          })}
        </ul>
      </Card>
    </section>

    <section>
      <SectionTitle>What this means</SectionTitle>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <Card>
          <p class="text-sm leading-relaxed text-ink-700">
            <strong class="font-semibold text-ink-900">{stats.totalVersions.toLocaleString()}</strong> published version entries —
            every revision of every entity across all dictionaries. The{" "}
            <code class="font-mono">version_history</code> array on each entity
            carries this provenance.
          </p>
        </Card>
        <Card>
          <p class="text-sm leading-relaxed text-ink-700">
            <strong class="font-semibold text-ink-900">{stats.multiVersionEntities.toLocaleString()}</strong> entities have more than one published version.
            Their detail pages support <a class="text-hex-700 underline decoration-dotted underline-offset-2" href="/docs/version-history/">version timeline, time travel, and diff view</a>.
          </p>
        </Card>
      </div>
    </section>
  </article>
</BaseLayout>
