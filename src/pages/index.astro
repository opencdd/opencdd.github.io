---
import BaseLayout from "~/layouts/BaseLayout.astro";
import EntityCountChips from "~/components/ui/EntityCountChips.astro";
import { listRegistryEntries } from "~/lib/data";
import { dictMetadataOrFallback } from "~/lib/dictMetadata";
import { getCollection } from "astro:content";

const entries = listRegistryEntries();
const dateFmt = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime())
  .slice(0, 3);

// "Published" excludes the demonstration fixture (oceanrunner). The
// demo is still shown in the grid below, but with a "Demonstration"
// badge and rendered last.
const publishedEntries = entries.filter((e) => e.slug !== "oceanrunner");
const totalEntities = publishedEntries.reduce(
  (sum, e) =>
    sum +
    Object.values(e.counts).reduce((s: number, n) => s + (n as number), 0),
  0,
);

// Sort entries: published dicts alphabetically, then oceanrunner last.
const sortedEntries = [...entries].sort((a, b) => {
  if (a.slug === "oceanrunner") return 1;
  if (b.slug === "oceanrunner") return -1;
  return a.slug.localeCompare(b.slug);
});
---

<BaseLayout
  title="OpenCDD — a modern browser for published IEC CDD data"
  description="Open-source tooling around the IEC Common Data Dictionary. Browse 21,500+ classes, properties, value lists, units, and relations across six published dictionaries."
>
  <section class="space-y-12">
    {/* Hero */}
    <header class="space-y-5 border-b border-ink-200 pb-10">
      <p class="text-xs font-medium uppercase tracking-[0.08em] text-accent-700">
        OpenCDD Browser
      </p>
      <h1
        class="max-w-3xl text-4xl font-semibold leading-tight tracking-tight text-ink-900 sm:text-5xl"
      >
        A modern, open-source browser for the
        <span class="text-accent-700">IEC Common Data Dictionary</span>.
      </h1>
      <p class="max-w-2xl text-base text-ink-600">
        {totalEntities.toLocaleString()} entities across{" "}
        {publishedEntries.length} published dictionaries — every class,
        property, value list, unit, and relation, with full version
        histories and multilingual definitions. Pre-rendered, statically
        hosted, and free to use.
      </p>
      <div class="flex flex-wrap items-center gap-3 pt-2">
        <a
          href="/docs/what-is-cdd/"
          class="inline-flex items-center gap-2 rounded-lg bg-accent-600 px-4 py-2 text-sm font-medium text-white shadow-sm transition hover:bg-accent-700"
        >
          What is CDD?
          <span aria-hidden="true">→</span>
        </a>
        <a
          href="#dictionaries"
          class="inline-flex items-center gap-2 rounded-lg border border-ink-200 bg-white px-4 py-2 text-sm font-medium text-ink-700 transition hover:border-ink-300 hover:text-ink-900"
        >
          Browse dictionaries
        </a>
        <a
          href="/docs/cdd-ontology-vs-uml-rdf/"
          class="inline-flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-ink-500 underline-offset-4 transition hover:text-accent-700 hover:underline"
        >
          How does CDD differ from UML/RDF?
        </a>
      </div>
    </header>

    {/* What is CDD — explainer */}
    <section class="grid gap-8 lg:grid-cols-[1fr_280px]">
      <div class="space-y-4">
        <h2 class="text-2xl font-semibold tracking-tight text-ink-900">
          What is the IEC Common Data Dictionary?
        </h2>
        <div class="space-y-3 text-sm leading-relaxed text-ink-600">
          <p>
            The IEC CDD is a structured, versioned, multilingual catalogue
            of product characteristics maintained by
            <a
              href="https://tc3.iec.ch/"
              class="text-accent-700 underline underline-offset-2">IEC TC 3</a
            >. It captures product concepts as entities called
            <em>classes</em> and their characteristics as entities called
            <em>properties</em> — each with a globally unique IRDI, a full
            version lineage, and translations.
          </p>
          <p>
            CDD is distinctive among modelling frameworks because its
            instances can themselves act as classes elsewhere in the
            dictionary — a four-layer model with native
            <em>power-type</em> semantics. This is what makes it richer
            than a plain UML class diagram and more structured than an
            RDF/OWL vocabulary.
          </p>
        </div>
        <div class="pt-2">
          <a
            href="/docs/cdd-ontology-vs-uml-rdf/"
            class="inline-flex items-center gap-1 text-sm font-medium text-accent-700 hover:text-accent-600"
          >
            Read the comparison
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>

      <aside class="rounded-2xl border border-ink-200/70 bg-sand-50/60 p-5 text-sm">
        <p
          class="mb-2 text-[10px] font-semibold uppercase tracking-[0.08em] text-ink-400"
        >
          The OpenCDD ecosystem
        </p>
        <ul class="space-y-1.5 text-ink-700">
          <li>
            <a
              href="https://github.com/opencdd/opencdd-ruby"
              class="hover:text-accent-700 hover:underline">opencdd-ruby</a
            >
            <span class="text-ink-400">— the model</span>
          </li>
          <li>
            <a
              href="https://github.com/opencdd/opencdd-ts"
              class="hover:text-accent-700 hover:underline">@opencdd/models</a
            >
            <span class="text-ink-400">— TS port</span>
          </li>
          <li>
            <span class="text-ink-400">this site —</span>
            <a
              href="/docs/what-is-opencdd/"
              class="hover:text-accent-700 hover:underline">the browser</a
            >
          </li>
        </ul>
      </aside>
    </section>

    {/* Dictionaries grid */}
    <section id="dictionaries" class="space-y-5 scroll-mt-20">
      <header class="space-y-1">
        <h2 class="text-2xl font-semibold tracking-tight text-ink-900">
          Dictionaries
        </h2>
        <p class="text-sm text-ink-500">
          Click any dictionary to browse its classes, properties, value
          lists, and relations.
        </p>
      </header>

      <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {sortedEntries.map((entry) => {
          const meta = dictMetadataOrFallback(entry.slug, entry.title);
          const isDemo = meta.demonstration === true;
          return (
            <li>
              <a
                href={`/d/${entry.slug}/`}
                class:list={[
                  "group flex h-full flex-col rounded-2xl border bg-white p-5 shadow-xs transition hover:shadow-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent-600",
                  isDemo
                    ? "border-dashed border-ink-300 hover:border-accent-300"
                    : "border-ink-200/70 hover:border-accent-300",
                ]}
              >
                <div class="flex items-baseline justify-between gap-2">
                  <h3 class="text-base font-semibold tracking-tight text-ink-900 group-hover:text-accent-700">
                    {meta.shortTitle}
                  </h3>
                  <code class="font-mono text-[10px] text-ink-400">{entry.slug}</code>
                </div>
                <div class="mt-1 flex flex-wrap items-center gap-1.5">
                  {isDemo ? (
                    <span class="rounded-full bg-amber-50 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-amber-700">
                      Demonstration
                    </span>
                  ) : (
                    <p class="text-[11px] font-medium uppercase tracking-wide text-ink-400">
                      {meta.publicationId}
                      {meta.publishedYear && ` · ${meta.publishedYear}`}
                      {meta.technicalCommittee && ` · ${meta.technicalCommittee}`}
                    </p>
                  )}
                </div>
                <p class="mt-3 line-clamp-3 text-xs leading-relaxed text-ink-600">
                  {meta.abstract || "No abstract available."}
                </p>
                <div class="mt-4">
                  <EntityCountChips counts={entry.counts} />
                </div>
                <div class="mt-4 text-sm font-medium text-accent-700 opacity-0 transition group-hover:opacity-100">
                  {isDemo ? "Explore the demo →" : "Browse →"}
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    </section>

    {/* Latest from the blog */}
    {posts.length > 0 && (
      <section class="space-y-5 border-t border-ink-200 pt-10">
        <header class="flex items-baseline justify-between">
          <h2 class="text-2xl font-semibold tracking-tight text-ink-900">
            From the blog
          </h2>
          <a
            href="/blog/"
            class="text-sm font-medium text-accent-700 hover:text-accent-600"
          >
            All posts →
          </a>
        </header>
        <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <li>
              <a
                href={`/blog/${post.id.replace(/\.mdx$/, "")}/`}
                class="group block rounded-2xl border border-ink-200/70 bg-white p-5 shadow-xs transition hover:border-accent-300 hover:shadow-md"
              >
                <p class="text-[11px] uppercase tracking-wide text-ink-400">
                  {dateFmt.format(post.data.published)}
                </p>
                <h3 class="mt-1 text-base font-semibold tracking-tight text-ink-900 group-hover:text-accent-700">
                  {post.data.title}
                </h3>
                {post.data.description && (
                  <p class="mt-2 line-clamp-2 text-xs leading-relaxed text-ink-600">
                    {post.data.description}
                  </p>
                )}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </section>
</BaseLayout>
